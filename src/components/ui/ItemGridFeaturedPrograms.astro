---
import { Icon } from 'astro-icon/components';
import { twMerge } from 'tailwind-merge';
import type { ItemGrid as Props } from '~/types';
import Button from '~/components/ui/Button.astro';

const { items = [], columns, defaultIcon = '', classes = {} } = Astro.props;

const {
  container: containerClass = '',
  panel: panelClass = '',
  title: titleClass = '',
  description: descriptionClass = '',
  icon: iconClass = '',
  action: actionClass = '',
} = classes;
---

{
  items && (
    <div
      class={twMerge(
        `grid gap-8 gap-x-12 sm:grid-cols-1 md:grid-cols-2 lg:grid-cols-${
          columns || (items.length > 3 ? 3 : items.length)
        }`,
        containerClass
      )}
    >
      {items.map(({ title, description, icon, callToAction, classes: itemClasses = {} }) => (
        <div class={twMerge('relative flex flex-col', panelClass, itemClasses?.panel)}>
          {(icon || defaultIcon) && (
            <Icon name={icon || defaultIcon} class={twMerge('mb-2 w-10 h-10 link', iconClass, itemClasses?.icon)} />
          )}
          <div class={twMerge('text-xl font-bold', titleClass, itemClasses?.title)}>{title}</div>
          {description && (
            <p
              class={twMerge('text-muted mt-2', descriptionClass, itemClasses?.description)}
              set:html={description}
            />
          )}
          {callToAction && (
            <div class={twMerge('mt-4', actionClass, itemClasses?.action)}>
              <Button variant="link" {...callToAction} />
            </div>
          )}
        </div>
      ))}
    </div>
  )
}
