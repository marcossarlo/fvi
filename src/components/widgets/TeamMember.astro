---
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Image from '~/components/common/Image.astro';

const {
  name,
  position,
  role,
  education,
  experience,
  trajectory,
  image,
  isReversed = false,
  isAfterContent = false,
  id,
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<WidgetWrapper
  id={id}
  containerClass={`max-w-7xl mx-auto ${isAfterContent ? 'pt-0 md:pt-0 lg:pt-0' : ''}`}
  bg={bg}
>
  <div class="mx-auto max-w-7xl p-4 md:px-8">
    <div class="mb-8">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-1">{name}</h3>
      <p class="text-secondary font-medium mb-6">{position}</p>
    </div>

    <div class={`md:flex ${isReversed ? 'md:flex-row-reverse' : 'md:flex-row'} md:gap-8 mb-8`}>
      <!-- Imagen -->
      <div class="mb-6 md:mb-0 md:flex-[2] lg:min-w-[480px] md:flex-shrink-0">
        {
          image && (
            <Image
              class="w-full rounded-lg shadow-lg"
              width={600}
              height={600}
              {...image}
            />
          )
        }
      </div>

      <!-- Contenido -->
      <div class="md:flex-[3]">
        {
          education && (
            <div class="mb-6">
              <h4 class="text-lg font-semibold text-primary mb-2 flex items-center gap-2">
                <span class="inline-block w-7 h-7 rounded-full bg-green-600 dark:bg-green-700 text-white flex items-center justify-center text-sm">
                  ✓
                </span>
                Educación:
              </h4>
              <p class="text-muted dark:text-slate-400 ml-9">{education}</p>
            </div>
          )
        }

        {
          experience && (
            <div class="mb-6">
              <h4 class="text-lg font-semibold text-primary mb-2 flex items-center gap-2">
                <span class="inline-block w-7 h-7 rounded-full bg-green-600 dark:bg-green-700 text-white flex items-center justify-center text-sm">
                  ✓
                </span>
                Experiencia:
              </h4>
              <p class="text-muted dark:text-slate-400 ml-9">{experience}</p>
            </div>
          )
        }

        {
          trajectory && (
            <div class="mb-6">
              <h4 class="text-lg font-semibold text-primary mb-2 flex items-center gap-2">
                <span class="inline-block w-7 h-7 rounded-full bg-green-600 dark:bg-green-700 text-white flex items-center justify-center text-sm">
                  ✓
                </span>
                Trayectoria:
              </h4>
              <p class="text-muted dark:text-slate-400 ml-9">{trajectory}</p>
            </div>
          )
        }
      </div>
    </div>

    <!-- CallToAction debajo de todo -->
    {
      role && (
        <div class="bg-gradient-to-r from-primary to-green-700 dark:from-primary dark:to-green-800 rounded-lg p-6 md:p-8 text-white shadow-lg">
          <h4 class="text-lg md:text-xl font-semibold mb-3">Responsabilidades</h4>
          <p class="text-base leading-relaxed">
            {role}
          </p>
        </div>
      )
    }
  </div>
</WidgetWrapper>
