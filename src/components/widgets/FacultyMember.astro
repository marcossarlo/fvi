---
import Image from '~/components/common/Image.astro';

/**
 * FacultyMember — card de profesor/investigador
 *
 * Layout: 230px imagen fija izquierda | resto contenido derecha
 * Mobile: columna única
 */
const {
  name,
  specialty,
  bio,
  awards = [],
  image,
  id,
} = Astro.props;

const hasBg = await Astro.slots.has('bg');
---

<section id={id} class="relative scroll-mt-[72px] py-10">
  {hasBg && (
    <div class="absolute inset-0 pointer-events-none -z-[1]" aria-hidden="true">
      <slot name="bg" />
    </div>
  )}

  <div class="mx-auto max-w-7xl px-6 lg:px-8">
    <div class="flex flex-col md:flex-row gap-8 items-start">

      <!-- Columna izquierda: Imagen 230px fija -->
      <div class="flex-shrink-0 mx-auto md:mx-0">
        {image && (
          <Image
            class="w-full object-cover object-top rounded-xl border-4 border-white dark:border-slate-400 shadow-[0_4px_28px_rgba(0,0,0,0.20)]"
            width={230}
            height={230}
            src={image.src}
            alt={image.alt ?? name}
          />
        )}
      </div>

      <!-- Columna derecha: Contenido -->
      <div class="flex-1 min-w-0">

        <h3 class="text-2xl sm:text-3xl font-bold tracking-tight dark:text-white leading-tight mb-1">
          {name}
        </h3>

        {specialty && (
          <p class="text-sm font-semibold tracking-widest uppercase text-secondary mb-5">
            {specialty}
          </p>
        )}

        {bio && (
          <div
            class="text-muted dark:text-slate-400 leading-relaxed space-y-3 text-base mb-6"
            set:html={bio}
          />
        )}

        {awards.length > 0 && (
          <ul class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3 mt-2">
            {awards.map((award: string) => (
              <li class="flex items-start gap-2 text-sm text-muted dark:text-slate-400">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="mt-0.5 h-4 w-4 flex-shrink-0 text-secondary"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
                  <polyline points="22 4 12 14.01 9 11.01" />
                </svg>
                <span set:html={award} />
              </li>
            ))}
          </ul>
        )}

      </div>
    </div>
  </div>
</section>
