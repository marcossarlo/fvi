---
import Image from '~/components/common/Image.astro';
import Button from '~/components/ui/Button.astro';

import type { Hero as Props } from '~/types';

const {
  title = await Astro.slots.render('title'),
  subtitle = await Astro.slots.render('subtitle'),
  tagline,
  content = await Astro.slots.render('content'),
  actions = await Astro.slots.render('actions'),
  image = await Astro.slots.render('image'),
  id,
  bg = await Astro.slots.render('bg'),
} = Astro.props;
---

<section class="relative md:-mt-[76px] not-prose flex items-center min-h-[75vh] md:min-h-[85vh]" {...id ? { id } : {}}>
    <div class="absolute inset-0 w-full h-full overflow-hidden pointer-events-none" aria-hidden="true">
        <slot name="bg">
            {bg ? (
            <Fragment set:html={bg} />
            ) : (
            image && (
                <div class="absolute inset-0 w-full h-full object-cover z-0">
                {typeof image === 'string' ? (
                    <Fragment set:html={image} />
                ) : (
                    <Image
                    class="absolute inset-0 w-full h-full object-cover object-right sm:object-center"
                    widths={[400, 768, 1024, 2040]}
                    sizes="100vw"
                    loading="eager"
                    width={2040}
                    height={1080}
                    {...image}
                    />
                )}
                {/* Overlay gradient: Más oscuro en móviles para lectura, degradado suave en desktop */}
                <div class="absolute inset-0 bg-slate-900/80 sm:bg-transparent sm:bg-gradient-to-r sm:from-slate-900/90 sm:via-slate-900/50 sm:to-transparent z-10"></div>
                </div>
            )
            )}
        </slot>
    </div>

    <div class="relative z-20 max-w-7xl mx-auto px-4 sm:px-6 w-full pt-28 pb-16 md:pt-[120px]">
        <div class="text-left pb-1 max-w-4xl">
        {tagline && (
            <div class="mb-6 flex items-center intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
            <span class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-orange-500/20 text-orange-400 border border-orange-500/30 text-sm font-semibold tracking-wider uppercase">
                <span class="relative flex h-2.5 w-2.5">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-orange-400 opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-orange-500"></span>
                </span>
                <span set:html={tagline} />
            </span>
            </div>
        )}
        {title && (
            <h1
            class="text-4xl md:text-5xl lg:text-7xl font-bold leading-tighter tracking-tighter mb-6 font-heading text-white intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
            set:html={title}
            />
        )}
        <div class="max-w-2xl">
            {subtitle && (
            <p
                class="text-lg md:text-xl text-gray-200 mb-8 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade font-medium leading-relaxed"
                set:html={subtitle}
            />
            )}
            {actions && (
            <div class="flex flex-col sm:flex-row gap-4 intersect-once intersect-quarter motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
                {Array.isArray(actions) ? (
                actions.map((action) => (
                    <div class="flex w-full sm:w-auto">
                    <Button {...(action || {})} class={[(action || {}).class || '', 'w-full sm:mb-0'].join(' ')} />
                    </div>
                ))
                ) : (
                <Fragment set:html={actions} />
                )}
            </div>
            )}
        </div>
        {content && <Fragment set:html={content} />}
        </div>
    </div>
</section>