    },
    {
      title: 'Diplomado en Metodología de la Investigación.',
      description:
        'Tras la superación del Programa de Postdoctorado el doctor/a recibirá el Título de Postdoctorado otorgado por Fondo Verde Institute, y también un Título de Experto/a en Metodología de la Investigación o similar.',
      icon: 'tabler:school',
    },
  ]}
