---
import Features3 from '~/components/widgets/Features3.astro';
import HeroSection from '~/components/widgets/HeroSection.astro';
---

<!-- 10. ¿Cómo aplicar? ******************************** -->
      <Features3
        id="como-aplicar"
        tagline="¿Cómo aplicar?"
        title="Proceso de Admisión"
        subtitle="Todo candidato para ser admitido a Fondo Verde, deberá cumplir con los reglamentos, políticas y criterios vigentes de admisión establecidos por la institución."
        columns={2}
        items={[
          {
            title: 'Determinación de Elegibilidad',
            description:
              'El Departamento de Admisiones, o en su caso el Comité de Admisiones, determinará a discreción la elegibilidad de los candidatos.',
            icon: 'tabler:user-check',
          },
          {
            title: 'Reserva de Criterios de Elegibilidad',
            description: 'El Instituto, se reserva el derecho de revelar los criterios de elegibilidad de los candidatos.',
            icon: 'tabler:lock',
          },
        ]}
        classes={{ container: 'max-w-4xl' }}
      />
      <!-- fases del proceso de admisión -->
      <HeroSection
        title="Las fases del proceso de admisión"
        image={{
          src: '~/assets/images/postdocs/fvi-proceso-admision.webp',
          alt: 'Las fases del proceso de admisión al posdoctorado',
        }}
      >
        <Fragment slot="subtitle"> El proceso para la inscripción al programa de postdoctorado es el siguiente: </Fragment>
      </HeroSection>
      <!-- Fin ¿CÓMO APLICAR? ************************************ -->
