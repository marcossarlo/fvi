---
import Layout from '~/layouts/PageLayout.astro';

import becasImage from '~/assets/images/fvi_Becas-Fondo-Verde-home.jpg';
import comoSeEstudiaImage from '~/assets/images/fvi_Financiamiento-home.jpg';
import comoAplicarImage from '~/assets/images/fvi_Como-Aplicar-home.jpg';
import maestriasImage from '~/assets/images/fvi_maestrias_home.webp';
import doctoradosImage from '~/assets/images/fvi_doctorados_home.webp';
import postdocsImage from '~/assets/images/fvi_postdocs_home.webp';

import HeroFVI from '~/components/widgets/HeroFVI.astro';
import Note from '~/components/widgets/Note.astro';
import Features from '~/components/widgets/Features.astro';
import FeatureInfo from '~/components/widgets/FeatureInfo.astro';
import FeaturedPrograms from '~/components/widgets/FeaturedPrograms.astro';
import Content from '~/components/widgets/Content.astro';
import FondoVerdeNews from '~/components/widgets/FondoVerdeNews.astro';
import Testimonials from '~/components/widgets/Testimonials.astro';
import FAQs from '~/components/widgets/FAQs.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';

const metadata = {
  title: 'Fondo Verde Institute — Maestrías, Doctorados y Posdoctorados en Medio Ambiente',
  ignoreTitleTemplate: true,
  description:
    'Fondo Verde Institute ofrece 8 Maestrías Universitarias, 9 Doctorados Oficiales y 7 Posdoctorados 100% en línea en medio ambiente, sostenibilidad y desarrollo ambiental para profesionales de Iberoamérica.',
  keywords:
    'maestría medio ambiente, doctorado sostenibilidad, posgrado ambiental online, maestría sostenibilidad, doctorado medio ambiente, posdoctorado ambiental, Fondo Verde Institute, IIFA, becas medio ambiente, formación ambiental Latinoamérica',
};
---

<Layout metadata={metadata}>
  <!-- Hero Widget ******************* -->
  <HeroFVI />
  
  <!-- Stats Widget ****************** -->
  <Stats
    stats={[
      { title: 'Maestrías', amount: '8' },
      { title: 'Doctorados Oficiales', amount: '9' },
      { title: 'Posdoctorados', amount: '7' },
      { title: 'Países de Iberoamérica', amount: '20+' },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 -z-10 h-full w-full bg-white bg-[linear-gradient(to_right,#f0f0f0_1px,transparent_1px),linear-gradient(to_bottom,#f0f0f0_1px,transparent_1px)] bg-[size:6rem_4rem]"><div class="absolute bottom-0 left-0 right-0 top-0 bg-[radial-gradient(circle_500px_at_50%_200px,#c6e8e6,transparent)]"></div></div>
    </Fragment>
  </Stats>

  <!-- Features Widget: ¿Por qué elegir FVI? *************** -->
  <Features
    id="por-que-fvi"
    tagline="Sobre el Instituto"
    title="¿Por qué elegir Fondo Verde Institute?"
    subtitle="Un ecosistema académico vinculante entre la sociedad civil, el mercado, el gobierno y los ecologistas, con el mejor contenido de formación ambiental y certificaciones de prestigio internacional."
    items={[
      {
        title: 'Formación 100% en línea',
        description:
          'Todos nuestros programas se desarrollan a través del Campus Virtual de Fondo Verde (fondoverdeopen.net), con interacción activa entre profesores-tutores y participantes de todo el mundo.',
        icon: 'tabler:device-laptop',
      },
      {
        title: 'Certificaciones de prestigio internacional',
        description:
          'Nuestros títulos están respaldados por una de las certificaciones más reconocidas en el sector ambiental, con validez y reconocimiento en Europa y Latinoamérica.',
        icon: 'tabler:certificate',
      },
      {
        title: 'Becas disponibles',
        description:
          'Fondo Verde ofrece un Programa de Becas para ciudadanos europeos y latinoamericanos, cubriendo hasta el 50% del costo del programa de posgrado.',
        icon: 'tabler:school',
      },
      {
        title: 'Comunidad iberoamericana',
        description:
          'Conecta con una red global de profesionales y académicos comprometidos con la sostenibilidad ambiental en más de 20 países de Iberoamérica.',
        icon: 'tabler:world',
      },
      {
        title: 'Investigación aplicada',
        description:
          'Actividades teóricas y prácticas orientadas a la conservación y el manejo sostenible de los recursos naturales, generando proyectos de alto impacto científico y social.',
        icon: 'tabler:microscope',
      },
      {
        title: 'Compatible con tu vida profesional',
        description:
          'La modalidad online permite equilibrar el estudio con la actividad laboral, adaptándose a los ritmos y zonas horarias de estudiantes en todo el continente.',
        icon: 'tabler:clock',
      },
    ]}
  />

  <!-- FeaturedPrograms Widget ******* -->
  <FeaturedPrograms
    tagline="Programas Destacados"
    columns={2}
    items={[
      {
        image: '/images/programs/fvi_fondo-hero.jpg',
        title: '<span class="text-primary">Maestría en</span> Ciencias de la Sostenibilidad',
        date: '13 de mayo de 2026',
        description: 'El Desarrollo Sostenible es el paradigma de desarrollo que la región visualiza como el modelo a buscar. Es el gran reto que se plantea a la humanidad de entender y asumir un proceso de cambio y transición para alcanzar nuevas formas de producir...',
        button: {
          text: 'Ver programa',
          href: '#',
          variant: 'primary'
        }
      },
      {
        image: '/images/programs/fvi_fondo-hero.jpg',
        title: '<span class="text-primary">Maestría en</span> Rehabilitación Ambiental Terrestre',
        date: '13 de mayo de 2026',
        description: 'La restauración ecológica, es una ciencia ambiental innovadora que aplica técnicas preventivas y correctoras de la degradación del medio natural y plantea la recuperación de forma sostenible, a largo plazo...',
        button: {
          text: 'Ver programa',
          href: '#',
          variant: 'primary'
        }
      },
      {
        image: '/images/programs/fvi_fondo-hero.jpg',
        title: '<span class="text-primary">Maestría en</span> Paisaje, Patrimonio y Estudios',
        date: '13 de mayo de 2026',
        description: 'El Desarrollo Sostenible es el paradigma de desarrollo que la región visualiza como el modelo a buscar. Es el gran reto que se plantea a la humanidad de entender y asumir un proceso de cambio y transición para alcanzar nuevas formas de producir...',
        button: {
          text: 'Ver programa',
          href: '#',
          variant: 'primary'
        }
      },
      {
        image: '/images/programs/fvi_fondo-hero.jpg',
        title: '<span class="text-primary">Maestría en</span> Gestión Ambiental',
        date: '13 de mayo de 2026',
        description: 'La restauración ecológica, es una ciencia ambiental innovadora que aplica técnicas preventivas y correctoras de la degradación del medio natural y plantea la recuperación de forma sostenible, a largo plazo...',
        button: {
          text: 'Ver programa',
          href: '#',
          variant: 'primary'
        }
      },
      {
        image: '/images/programs/fvi_fondo-hero.jpg',
        title: '<span class="text-primary">Maestría en</span> Paisaje, Patrimonio y Estudios',
        date: '13 de mayo de 2026',
        description: 'El patrimonio cultural y natural constituye uno de los recursos más valiosos de la humanidad. Su conservación y gestión sostenible son fundamentales para el desarrollo de las sociedades...',
        button: {
          text: 'Ver programa',
          href: '#',
          variant: 'primary'
        }
      }
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-repeat opacity-70 dark:opacity-50" style="background-image: url('/images/fvi_grey_background.jpg');"></div>
       <!-- <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div> -->
      <!-- <div class="absolute inset-0 -z-10 h-full w-full bg-white bg-[linear-gradient(to_right,#f0f0f0_1px,transparent_1px),linear-gradient(to_bottom,#f0f0f0_1px,transparent_1px)] bg-[size:6rem_4rem]"><div class="absolute bottom-0 left-0 right-0 top-0 bg-[radial-gradient(circle_800px_at_100%_200px,#c6e8e6,transparent)]"></div></div> -->
    </Fragment>
  </FeaturedPrograms>

  <!-- FeatureInfo Widget: Oportunidades de Formación ************** -->
  <FeatureInfo
    title="Oportunidades de Formación"
    subtitle="Descubre nuestro Programa de Becas, conoce la modalidad flexible de estudio en línea y aprende paso a paso cómo aplicar a nuestros posgrados ambientales."
    tagline="Impacto sostenible"
    columns={3}
    items={[
      {
        image: becasImage,
        iconLink: {
          href: '#',
          icon: 'tabler:chevron-right',
          ariaLabel: 'Ver más sobre Becas'
        },
        title: 'Becas Fondo Verde',
        content: 'Fondo Verde ofrece un Programa de Becas para ciudadanos europeos y latinoamericanos, con acceso especial a sus posgrados en línea. La beca cubre el <strong>50% del costo</strong>.',
        buttonLink: {
          text: 'Leer Más',
          href: '#',
          variant: 'primary'
        }
      },
      {
        image: comoSeEstudiaImage,
        iconLink: {
          href: 'https://www.fondoverdeopen.net',
          icon: 'tabler:chevron-right',
          ariaLabel: 'Ver más sobre Maestrías'
        },
        title: '¿Cómo se estudia?',
        content: 'Todos nuestros programas se desarrollan a través del <strong>Campus Virtual de Fondo Verde</strong> (fondoverdeopen.net), que permite la interacción profesor-tutor y de los participantes entre sí.',
        buttonLink: {
          text: 'Leer Más',
          href: 'https://www.fondoverdeopen.net/',
          variant: 'primary'
        }
      },
      {
        image: comoAplicarImage,
        iconLink: {
          href: '#',
          icon: 'tabler:chevron-right',
          ariaLabel: 'Ver más sobre Doctorados'
        },
        title: '¿Cómo Aplicar?',
        content: 'Todo candidato para ser admitido a Fondo Verde, deberá cumplir con los reglamentos, políticas y criterios vigentes de admisión establecidos por la institución.',
        buttonLink: {
          text: 'Leer Más',
          href: '#',
          variant: 'primary'
        }
      }
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-olive-50 dark:bg-transparent"></div>
    </Fragment>
  </FeatureInfo>

  <!-- Testimonials Widget: Alumni ******* -->
  <Testimonials
    tagline="Alumni"
    title="Testimonios de nuestros estudiantes"
    subtitle="Voces de quienes han transformado su carrera profesional a través de nuestros programas de posgrado en medio ambiente."
    testimonials={[
      {
        name: 'Felix Ortiz',
        job: 'Master de Proyectos Ambientales · México',
        testimonial:
          'Agradezco a todo el equipo del Instituto y Fondo Verde por haberme dado la oportunidad de cerrar exitosamente mi ciclo de aprendizaje. Una mención especial por el excelente trabajo del Dr. Walter Castro Aponte. Hoy he recibido los documentos que acreditan el master.',
      },
      {
        name: 'Germán Onofre',
        job: 'MBA en Negocios Ambientales · Perú',
        testimonial:
          'Quedo agradecido a Fondo Verde e IIFA por haberme otorgado la oportunidad de ser parte de esta formación. Es una experiencia extraordinaria de aprendizaje y formación profesional, sin barreras ni fronteras.',
      },
      {
        name: 'Pedro Fuentes Vásquez',
        job: 'MBA en Administración Ambiental · Ecuador',
        testimonial:
          'Quiero agradecer la oportunidad brindada por IIFA. Este MBA me deja totalmente satisfecho por su seriedad, compromiso y su alto nivel de contenido. Una institución que verdaderamente marca la diferencia en la formación ambiental.',
      },
    ]}
    callToAction={{
      text: 'Ver más testimonios',
      href: '/alumni',
      variant: 'secondary',
    }}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 z-[-2] bg-white bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(120,119,198,0.3),rgba(255,255,255,0))]"></div>
    </Fragment>
  </Testimonials>

    <!-- Content Widget: MAESTRÍAS **************** -->
  <Content
    isReversed
    tagline="Formación de Excelencia"
    title="Maestrías, Doctorados y Posdoctorados para un Futuro Sostenible"
    items={[
      {
        title: 'Formación de referencia en el continente',
        description:
          'Las Maestrías preparan profesionales líderes en la protección del medio ambiente, con enfoque en planificación y gestión de los problemas ambientales globales.',
      },
      {
        title: 'Flexibilidad, internacionalización y prestigio',
        description:
          'Programas online que permiten equilibrar trabajo y estudio, expandir tu red global y acceder a una formación reconocida por su excelencia académica.',
      },
      {
        title: 'Estructura académica sólida',
        description:
          'Con una duración de 2 años (6 trimestres), el plan incluye 9 cursos básicos, un Proyecto Terminal y la opción de titulación, sumando 1,440 horas lectivas (90 créditos).',
      },
    ]}
    image={{
      src: maestriasImage,
      alt: 'Maestrías Universitarias - Fondo Verde Institute',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2"><span class="text-accent">8</span> Maestrías Universitarias</h3>
    </Fragment>

    <Fragment slot="bg">
      <!-- <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div> -->
       <div class="absolute inset-0 -z-10 h-full w-full bg-white bg-[linear-gradient(to_right,#8080800a_1px,transparent_1px),linear-gradient(to_bottom,#8080800a_1px,transparent_1px)] bg-[size:14px_24px]"></div>
    </Fragment>
  </Content>

  <!-- Content Widget: DOCTORADOS **************** -->
  <Content
    isAfterContent
    items={[
      {
        title: 'Formación especializada con impacto global',
        description:
          'Nuestros Doctorados introducen al investigador en metodologías avanzadas para el estudio del medio ambiente y la planificación del desarrollo, generando un efecto positivo en comunidades y regiones.',
      },
      {
        title: 'Investigación original y cultura interdisciplinaria',
        description:
          'El programa fomenta proyectos científicos coherentes y tesis originales, equivalentes al PhD internacional, fortaleciendo competencias y habilidades de investigación con enfoque interdisciplinario.',
      },
      {
        title: 'Estructura académica completa',
        description:
          'Con una duración de 24 meses (8 trimestres), el Doctorado combina cursos teóricos, seminarios de investigación, tutoría académica, proyecto de tesis y publicación de un artículo científico, sumando 1,440 horas lectivas (90 créditos).',
      },
    ]}

    image={{
      src: doctoradosImage,
      alt: 'Doctorados Oficiales - Fondo Verde Institute',
    }}
  >
    <Fragment slot="content"><h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2"><span class="text-accent">9</span> Doctorados Oficiales</h3>
    </Fragment>
    <Fragment slot="bg">
      <!-- <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div> -->
       <div class="absolute inset-0 -z-10 h-full w-full bg-white bg-[linear-gradient(to_right,#8080800a_1px,transparent_1px),linear-gradient(to_bottom,#8080800a_1px,transparent_1px)] bg-[size:14px_24px]"><div class="absolute left-0 right-0 top-0 -z-10 m-auto h-[310px] w-[310px] rounded-full bg-green-500 opacity-20 blur-[100px]"></div></div>
    </Fragment>
  </Content>

  <!-- Content Widget: POSTDOCS **************** -->
  <Content
    isReversed
    isAfterContent
    items={[
      {
        title: 'Producción científica en sustentabilidad',
        description:
          'El Postdoctorado fortalece la investigación en temas ambientales, dirigido a doctores de Iberoamérica que buscan responder a conflictos locales y regionales con proyectos de relevancia científica.',
      },
      {
        title: 'Nuevas perspectivas y articulación regional',
        description:
          'El programa abre caminos para estrategias de desarrollo sustentable en Latinoamérica, vinculando políticas públicas y privadas con propuestas concretas y co-construcción de conocimiento.',
      },
      {
        title: 'Estructura académica flexible',
        description:
          'Con duración de 6 a 12 meses, el Postdoctorado consiste en un plan de actividades supervisado por un director y culmina con la publicación de un artículo arbitrado por jurados, uno de ellos internacional.',
      },
    ]}

    image={{
      src: postdocsImage,
      alt: 'Posdoctorados - Fondo Verde Institute',
    }}
  >
    <Fragment slot="content"><h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2"><span class="text-accent">7</span> Posdoctorados</h3>
    </Fragment>
    <Fragment slot="bg">
      <!-- <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div> -->
       <div class="absolute inset-0 -z-10 h-full w-full bg-white bg-[linear-gradient(to_right,#8080800a_1px,transparent_1px),linear-gradient(to_bottom,#8080800a_1px,transparent_1px)] bg-[size:14px_24px]"></div>
    </Fragment>
  </Content>

  <!-- Note Widget ******************* -->
  <Note
    icon="tabler:calendar-event"
    title="Próximos inicios:&nbsp;"
    description="<strong>Posdoctorados</strong> · 4 mar 2026 &nbsp;&nbsp;|&nbsp;&nbsp; <strong>Doctorados y Maestrías</strong> · 13 may 2026 &nbsp;&nbsp;—&nbsp;&nbsp; <a href='/contact' class='font-bold text-secondary hover:text-primary underline underline-offset-2'>Solicitar información</a>"
  />

  <!-- FAQs Widget: Preguntas Frecuentes ******************* -->
  <FAQs
    title="Preguntas Frecuentes"
    subtitle="Encuentra respuestas a las consultas más habituales sobre nuestros programas, admisiones, becas y metodología de estudio."
    tagline="FAQs"
    classes={{ container: 'max-w-6xl' }}
    items={[
      {
        title: '¿Cómo funciona el Programa de Becas Fondo Verde?',
        description:
          'Fondo Verde ha establecido un Programa de Becas que permite a ciudadanos europeos y latinoamericanos acceder en forma especial a los cursos impartidos en línea. La beca cubre el 50% del costo del programa. Puedes consultar los requisitos detallados en la sección de Becas.',
      },
      {
        title: '¿Cuándo es el próximo inicio de clases?',
        description:
          'El próximo período académico inicia el 13 de mayo de 2026. Las admisiones están abiertas hasta el 25 de abril de 2026. Te recomendamos completar tu solicitud con anticipación para asegurar tu plaza.',
      },
      {
        title: '¿Cómo se desarrollan los programas en línea?',
        description:
          'Todos los programas se desarrollan a través del Campus Virtual de Fondo Verde (fondoverdeopen.net). La plataforma permite la interacción constante entre el profesor-tutor y los participantes, con materiales de estudio, foros, evaluaciones y sesiones sincrónicas.',
      },
      {
        title: '¿Qué documentos necesito para aplicar?',
        description:
          'Todo candidato debe cumplir con los reglamentos, políticas y criterios vigentes de admisión establecidos por la institución. El proceso incluye la revisión de documentos académicos previos. Puedes consultar todos los requisitos en la sección ¿Cómo Aplicar?',
      },
      {
        title: '¿Los títulos son reconocidos internacionalmente?',
        description:
          'Sí. Fondo Verde Institute cuenta con certificaciones de gran prestigio en el sector ambiental, con reconocimiento tanto en Europa como en Latinoamérica. Nuestros graduados ejercen su actividad profesional en múltiples países de Iberoamérica.',
      },
      {
        title: '¿Puedo estudiar mientras trabajo?',
        description:
          'Absolutamente. La modalidad 100% online está diseñada para que puedas equilibrar tu actividad profesional con los estudios. Los materiales y actividades están disponibles de forma flexible, adaptándose a distintas zonas horarias y ritmos de trabajo.',
      },
    ]}
  />

  <!-- Noticias FVI Widget ******* -->
  <FondoVerdeNews
    title="Noticias y novedades de Fondo Verde"
    information="Fondo Verde publica material producido en nuestra redacción y por colaboradores en el exterior. Presentamos las noticias más relevantes de nuestro accionar en la región, siendo un canal online dedicado a la educación en medio ambiente."
  />
</Layout>
