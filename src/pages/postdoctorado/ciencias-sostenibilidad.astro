---
import HeroPrograms from '~/components/widgets/HeroPrograms.astro';
import Content from '~/components/widgets/Content.astro';
import HeroSection from '~/components/widgets/HeroSection.astro';
import Steps from '~/components/widgets/Steps.astro';
import Layout from '~/layouts/PageLayout.astro';
import Features2 from '~/components/widgets/Features2.astro';
import FacultyMember from '~/components/widgets/FacultyMember.astro';
import { faculty } from '~/data/faculty';
import DatosEstadisticas from '~/components/postdoctorado/DatosEstadisticas.astro';
import Modalidades from '~/components/postdoctorado/Modalidades.astro';
import Estructura from '~/components/postdoctorado/Estructura.astro';
import ComoSeEstudia from '~/components/postdoctorado/ComoSeEstudia.astro';
import Becas from '~/components/postdoctorado/Becas.astro';
import ComoAplicar from '~/components/postdoctorado/ComoAplicar.astro';
import InscripcionTasas from '~/components/postdoctorado/InscripcionTasas.astro';
import Pagos from '~/components/postdoctorado/Pagos.astro';
import Solicitudes from '~/components/postdoctorado/Solicitudes.astro';
import ProgramTOC from '~/components/widgets/ProgramTOC.astro';

const metadata = {
    title: 'Posdoctorado en Ciencias de la Sostenibilidad',
    description:
    'Programa de Posdoctorado en Ciencias de la Sostenibilidad para doctores e investigadores. Desarrolla proyectos sobre ODS, cambio climático y políticas ambientales en Iberoamérica.',
    keywords:
    'Posdoctorado en Sostenibilidad, Ciencias de la Sostenibilidad, ODS, investigación ambiental, cambio climático, desarrollo sostenible, Fondo Verde Institute',
};

const tabs = [
  { label: '1. Presentación', id: 'presentacion' },
  { label: '2. El Postdoctorado', id: 'el-postdoctorado' },
  { label: '3. Modalidades', id: 'modalidades' },
  { label: '4. Estructura', id: 'estructura' },
  { label: '5. Asignaturas', id: 'asignaturas' },
  { label: '6. ¿Cómo se estudia?', id: 'como-se-estudia' },
  { label: '7. Claustro', id: 'claustro' },
  { label: '8. Certificación', id: 'certificacion' },
  { label: '9. Becas', id: 'becas' },
  { label: '10. ¿Cómo aplicar?', id: 'como-aplicar' },
  { label: '11. Inscripción', id: 'inscripcion' },
  { label: '12. Pagos', id: 'pagos' },
  { label: '13. Solicitudes', id: 'solicitudes' },
];
---

<Layout metadata={metadata} showSecondaryNav={false}>
    <!-- HeroPrograms ********************************************** -->
    <HeroPrograms
        tagline="Convocatoria Abierta 2026"
        subtitle="La construcción de un futuro sostenible requiere la implicación de la comunidad científica."
        actions={[
            {
            variant: 'primary',
            text: 'Solicita información',
            href: '#solicitudes',
            icon: 'tabler:mail-forward',
            class: '!bg-primary !border-primary !text-white hover:!bg-secondary hover:!border-secondary transition-colors duration-300',
            },
            {
            variant: 'secondary',
            text: 'Ver Folleto Académico',
            href: 'https://drive.google.com/uc?export=download&id=1Jezy7cdRzCJLTZl_G514ESeFmq-J5HoF',
            icon: 'tabler:download',
            class: '!bg-transparent !text-white !border-[1px] !border-solid !border-white/50 hover:!bg-white/10 hover:!text-white hover:!border-white transition-all duration-300',
            },
        ]}
        image={{
            src: '~/assets/images/postdocs/fvi-postdoc-ciencias-sostenibilidad.webp',
            alt: 'Postdoctorado en Ciencias de la Sostenibilidad',
        }}
    >
        <Fragment slot="title">
            Posdoctorado en <br />
            <span class="text-primary dark:text-accent"> Ciencias de la <br />Sostenibilidad</span>
        </Fragment>
    </HeroPrograms>

    <!-- DatosEstadisticas -->

    <DatosEstadisticas />  

    <div class="relative max-w-[100vw] overflow-x-hidden">
        <!-- Desktop Sidebar & Mobile Floating Pill -->
        <ProgramTOC tabs={tabs} />
        
        <!-- Main Content Wrapper that creates space for the Desktop Sidebar -->
        <div class="lg:ml-64 2xl:ml-[18rem] pb-24 lg:pb-0 transition-all duration-300">

        <!-- 1. PRESENTACIÓN *********************************** -->
        <Content
            id="presentacion"
            tagline="Presentación"
            title="Loraine Giraud, PhD"
            subtitle="Directora del Postdoctorado"
            items={[
            {
                title: 'Programa en extenso',
                icon: 'tabler:download',
                callToAction: {
                text: 'Descargar el Programa en Extenso',
                href: 'https://drive.google.com/uc?export=download&id=1Jezy7cdRzCJLTZl_G514ESeFmq-J5HoF',
                variant: 'primary',
                },
            },
            ]}
            image={{
            src: '~/assets/images/users/fvi-loraine-giraud.webp',
            alt: 'ALT',
            }}
        >
            <Fragment slot="content">
            <h3 class="text-xl font-semibold tracking-tight dark:text-white mb-2">
                La construcción de un futuro sostenible requiere la <span class="text-primary">implicación de la comunidad científica</span>.
            </h3>
            <p class="pb-1">Los problemas socioambientales que caracterizan la situación de emergencia planetaria, precisa una nueva área de conocimientos, una Ciencia de la Sostenibilidad, que integre diversos campos y un camino unificado para el desarrollo y la conservación.</p>
            <p class="pb-1">El programa de <span class="text-primary font-semibold">Posdoctorado en</span> <span class="text-secondary font-semibold">Ciencias de la Sostenibilidad</span>, pretende mejorar nuestra comprensión de la interacción entre los sistemas naturales y sociales y generar conocimiento sobre los Objetivos de Desarrollo Sostenible ODS, incluyendo una discusión sobre sus posibles tensiones y alcances. Junto con expertos en desarrollo sostenible a escala internacional, realizará investigaciones sobre los desafíos sociales relacionados con las interacciones de la sostenibilidad global, los ecosistemas, la salud y el cambio climático. Además, estudiará la integración de los ODS en los objetivos de negocio para lograr resultados sostenibles en las empresas, el gobierno y las organizaciones.</p>
            </Fragment>

            <Fragment slot="bg">
            <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
            </Fragment>
        </Content>

        <!-- 2. EL POSTDOCTORADO ******************************* -->
        <Features2
            id="el-postdoctorado"
            tagline="El Postdoctorado"
            title="¿Por qué hacer el postdoctorado?"
            subtitle='Los desafíos que enfrenta la sociedad son complejos y multidimensionales, lo que lleva a nuevos paradigmas asociados con el desarrollo sostenible. El <span class="text-primary font-semibold">Posdoctorado en</span> <span class="text-secondary font-semibold">Ciencias de la Sostenibilidad</span>, tiene por objetivo divulgar y fortalecer la producción de trabajos de relevancia científica cuyo objeto sea analizar la naturaleza y sus relaciones con el ser humano, al tiempo de contribuir al desarrollo de políticas ambientales sostenibles en el marco de la administración, la empresa y la industria. El Programa está dirigido a Doctores de toda Iberoamérica y de cualquier disciplina, con una <strong>duración mínima de 6 meses</strong> y <strong>máxima de 1 año</strong> y consiste en la realización de un plan de actividades, cuyo resultado debe ser la publicación de un artículo arbitrado por dos jurados, uno de ellos internacional y la presentación de un informe del cumplimiento de las tareas previstas en el plan.'
            columns={2}
            items={[
            {
                title: 'Objetivos del Programa',
                description:
                'El Programa de <span class="text-primary font-semibold">Posdoctorado en</span> <span class="text-secondary font-semibold">Ciencias de la Sostenibilidad</span>, se orientará de modo particular a: <ul class="list-disc ml-6 mt-2 space-y-1 text-muted"><li>Contribuir a la creación de conocimiento académico mediante el desarrollo de métodos, sistemas, conceptos y herramientas para la gestión de la sostenibilidad.</li><li>Realizar investigación exhaustiva y a múltiples escalas sobre los desafíos de la aplicación de los Objetivos de Desarrollo Sostenible - ODS, incluyendo una discusión sobre sus posibles tensiones y alcances.</li><li>Integrar especialistas latinoamericanos de alto perfil en un foro académico de medio ambiente que estudie políticas, estrategias y tecnologías para fomentar una transición hacia una economía sostenible.</li><li>Presentar a la comunidad científica en México y Latinoamérica, conocimientos técnicos y herramientas de gestión necesarias para abordar, desde una visión multidisciplinar, cualquier proyecto empresarial o industrial con repercusión en el medio ambiente, dentro del marco de una economía social y sostenible.</li></ul>',
                icon: 'tabler:circle-plus',
            },
            {
                title: 'Perfil del destinatario',
                description:
                'El programa está dirigido a: <ul class="list-disc ml-6 mt-2 space-y-1 text-muted"><li>Doctores de universidades extranjeras y nacionales graduados en ecología global, biodiversidad, ciencias de la tierra o una disciplina relacionada, que persigan desarrollar un proyecto de investigación novedoso cuyo objeto sea analizar los desafíos de la sostenibilidad desde una perspectiva crítica y enfoques basados en soluciones.</li><li>Doctores de toda Iberoamérica, que posean especial interés en temas de sustentabilidad ambiental y que busquen desarrollar un proyecto de investigación riguroso en el límite entre las ciencias sociales y naturales.</li><li>Docentes, profesionales, asesores e investigadores locales, nacionales e internacionales con título doctoral, que muestren interés por la temática del ambiente y el desarrollo sustentable.</li><li>Profesionales recién doctorados especialmente motivados en formarse y/o profundizar en el paradigma ambiental como nueva forma de abordar la realidad y en el desarrollo sustentable como desafío a alcanzar.</li><li>Funcionarios y/o responsables de las políticas públicas a nivel local, regional o nacional en esta área o afines, que hayan obtenido su doctorado en alguna institución de reconocido prestigio.</li><li>Doctores que ejerzan la docencia y/o educadores en general interesados en la formación transdisciplinaria, el enfoque holístico y la mirada integral que el ambiente requiere.</li></ul>',
                icon: 'tabler:users',
            },
            ]}
        />

        <!-- 3. MODALIDADES -->
        <Modalidades />

        <!-- 4. ESTRUCTURA -->
        <Estructura />

        <!-- 5. ASIGNATURAS ************************************ -->
        <HeroSection
            id="asignaturas"
            tagline="Asignaturas"
            title="Asignaturas de la Programación"
            image={{
            src: '~/assets/images/postdocs/fvi-postdoc-CS-Asignaturas.webp',
            alt: 'Asignaturas del programa de Posdoctorado en Sistemas de Gestión Medioambiental',
            }}
        >
            <Fragment slot="bg">
                <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
                </Fragment>
                <Fragment slot="subtitle">
                Son asignaturas obligatorias propuestas en la programación vigente, y a la vez es vinculante con el <span class="text-primary font-semibold">Trabajo Final de Investigación</span> - <span class="text-primary font-semibold">TFI</span>, por cuanto el postDoc deberá escoger una de las asignaturas de la programación y
                desarrollar algún aspecto que le resulte de interés.
            </Fragment>
        </HeroSection>

        <!-- 6. CÓMO SE ESTUDIA? -->
        <ComoSeEstudia />

        <!-- 7. CALUSTRO *************************************** -->
        <Content
            id="claustro"
            tagline="Claustro"
            title="Claustro Académico"
            items={[
            {
                title: 'Staff académico especializado',
                description:
                'El programa cuenta con un equipo de alto nivel, conformado por docentes universitarios e investigadores expertos en cada materia de conocimiento.',
                icon: 'tabler:users-group',
            },
            {
                title: 'Profesionales en activo',
                description:
                'Participan especialistas provenientes de la administración pública y de la empresa privada, aportando experiencia práctica en la gestión de proyectos.',
                icon: 'tabler:briefcase',
            },
            {
                title: 'Colaboración institucional',
                description:
                'Se suman profesionales de primer nivel de empresas, organismos oficiales e instituciones, directamente implicados en las áreas de conocimiento que abarca el posdoctorado.',
                icon: 'tabler:building',
            },
            ]}
            image={{
            src: '~/assets/images/fvi-claustro-academico.webp',
            alt: 'Claustro académico de Fondo Verde',
            }}
        >
            <Fragment slot="bg">
                <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
            </Fragment>
        </Content>
        <!-- Miembros del claustro -->
        {
            ['loraine-giraud', 'gonzalo-fuente', 'angel-guillemes', 'alberto-jimenez', 'erick-brenes'].map((id) => (
            <FacultyMember {...faculty[id]}>
                <Fragment slot="bg">
                <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark" />
                </Fragment>
            </FacultyMember>
            ))
        }

        <!-- 8. CERTIFICACIÓN ********************************** -->
        <Steps
            id="certificacion"
            tagline="Certificación"
            title="Evaluación y certificación"
            subtitle="Una vez cumplido y evaluado el Informe del Plan de Actividades y superado el Trabajo Final de Investigación, se expedirá un <strong>Diploma que acredite haber cursado el Programa de Postdoctorado</strong>."
            items={[
            {
                title: 'Diploma Oficial <br> <span class="font-normal">y Reconocimiento Institucional</span>',
                description: `El Diploma de Postdoctorado es expedido por <strong>Fondo Verde</strong>, inscrito en el Registro de Entidades Colaboradoras de la Junta de Castilla y León (España), en materia de Formación Profesional Ocupacional, con número <strong>11001</strong>.`,
                icon: 'tabler:certificate',
            },
            {
                title: 'Apostillado <br> <span class="font-normal">y Validez Internacional del Diploma</span>',
                description:
                'Desde España se realiza el proceso de apostillado por la Haya y la legitimación de firmas para que no tenga problemas a la hora de presentar el Diploma en un país fuera de España.',
                icon: 'tabler:certificate',
            },
            ]}
            classes={{ container: 'max-w-4xl' }}
        />
        <Features2
            columns={2}
            items={[
            {
                title: 'Requisitos para la Certificación PMPA™',
                description:
                'Los participantes que pretendan obtener la licencia <strong>PMA™ Director de Sostenibilidad Certificado</strong>, tienen que acreditar los requisitos de certificación relacionados con la credencial seleccionada.',
                icon: 'tabler:certificate-2',
            },
            {
                title: 'Licencia como Instructor PMPA™',
                description:
                'Los solicitantes que no cumplen los requisitos de experiencia pueden ser elegibles para una licencia <strong>PMA™ Adjunto a Dirección de Sostenibilidad Asociado</strong>.',
                icon: 'tabler:certificate-2',
            },
            ]}
            classes={{ container: 'max-w-4xl' }}
        />

        <!-- 9. BECAS -->
        <Becas />

        <!-- 10. CÓMO APLICAR? -->
        <ComoAplicar />

        <!-- 11. INSCRIPCIÓN Y TASAS -->
        <InscripcionTasas />

        <!-- 12. PAGOS -->
        <Pagos />

        <!-- 13. SOLICITUDES -->
        <Solicitudes />

        </div>
    </div>
</Layout>
