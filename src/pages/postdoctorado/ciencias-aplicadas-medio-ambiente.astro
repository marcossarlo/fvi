---
import HeroPrograms from '~/components/widgets/HeroPrograms.astro';
import Content from '~/components/widgets/Content.astro';
import HeroSection from '~/components/widgets/HeroSection.astro';
import Steps from '~/components/widgets/Steps.astro';
import Layout from '~/layouts/PageLayout.astro';
import Features2 from '~/components/widgets/Features2.astro';
import FacultyMember from '~/components/widgets/FacultyMember.astro';
import { faculty } from '~/data/faculty';
import DatosEstadisticas from '~/components/postdoctorado/DatosEstadisticas.astro';
import Modalidades from '~/components/postdoctorado/Modalidades.astro';
import Estructura from '~/components/postdoctorado/Estructura.astro';
import ComoSeEstudia from '~/components/postdoctorado/ComoSeEstudia.astro';
import Becas from '~/components/postdoctorado/Becas.astro';
import ComoAplicar from '~/components/postdoctorado/ComoAplicar.astro';
import InscripcionTasas from '~/components/postdoctorado/InscripcionTasas.astro';
import Pagos from '~/components/postdoctorado/Pagos.astro';
import Solicitudes from '~/components/postdoctorado/Solicitudes.astro';
import ProgramTOC from '~/components/widgets/ProgramTOC.astro';

const metadata = {
  title: 'Posdoctorado en Ciencias Aplicadas al Medio Ambiente',
  description:
    'Impulsa tu investigación científica con el Posdoctorado en Ciencias Aplicadas al Medio Ambiente. Un programa de 6 a 12 meses enfocado en sostenibilidad, tecnologías limpias y la transición hacia una economía sostenible, dirigido a doctores en Iberoamérica.',
  keywords:
    'posdoctorado, ciencias ambientales, ciencias aplicadas al medio ambiente, sustentabilidad, desarrollo sostenible, investigación posdoctoral, energías renovables, economía sostenible, Fondo Verde Institute, doctores Iberoamérica',
};

const tabs = [
  { label: '1. Presentación', id: 'presentacion' },
  { label: '2. El Postdoctorado', id: 'el-postdoctorado' },
  { label: '3. Modalidades', id: 'modalidades' },
  { label: '4. Estructura', id: 'estructura' },
  { label: '5. Asignaturas', id: 'asignaturas' },
  { label: '6. ¿Cómo se estudia?', id: 'como-se-estudia' },
  { label: '7. Claustro', id: 'claustro' },
  { label: '8. Certificación', id: 'certificacion' },
  { label: '9. Becas', id: 'becas' },
  { label: '10. ¿Cómo aplicar?', id: 'como-aplicar' },
  { label: '11. Inscripción', id: 'inscripcion' },
  { label: '12. Pagos', id: 'pagos' },
  { label: '13. Solicitudes', id: 'solicitudes' },
];
---

<Layout metadata={metadata} showSecondaryNav={false}>
  <!-- HeroPrograms ********************************************** -->
  <HeroPrograms
    tagline="Convocatoria Abierta 2026"
    subtitle="Los problemas ambientales requieren soluciones eficaces e innovadoras en los distintos ámbitos del medio ambiente."
    actions={[
      {
        variant: 'primary',
        text: 'Solicita información',
        href: '#solicitudes',
        icon: 'tabler:mail-forward',
        class: '!bg-primary !border-primary !text-white hover:!bg-secondary hover:!border-secondary transition-colors duration-300',
      },
      {
        variant: 'secondary',
        text: 'Ver Folleto Académico',
        href: 'https://drive.usercontent.google.com/download?id=1BvjHpeuctXB0sxdbLSwWepcPrnV5GwrM&export=download',
        icon: 'tabler:download',
        class: '!bg-transparent !text-white !border-[1px] !border-solid !border-white/50 hover:!bg-white/10 hover:!text-white hover:!border-white transition-all duration-300',
      },
    ]}
    image={{
      src: '~/assets/images/postdocs/fvi-postdoc-ciencias-aplicadas-medio-ambiente.webp',
      alt: 'Posdoctorado en Ciencias Aplicadas al Medio Ambiente - Fondo Verde Institute',
    }}
  >
    <Fragment slot="title">
      Posdoctorado en <br />
      <span class="text-primary dark:text-accent"> Ciencias Aplicadas <br />al Medio Ambiente</span>
    </Fragment>
  </HeroPrograms>

  <!-- DatosEstadisticas -->

  <DatosEstadisticas />  

  <div class="relative max-w-[100vw] overflow-x-hidden">
    <!-- Desktop Sidebar & Mobile Floating Pill -->
    <ProgramTOC tabs={tabs} />
    
    <!-- Main Content Wrapper that creates space for the Desktop Sidebar -->
    <div class="lg:ml-64 2xl:ml-[18rem] pb-24 lg:pb-0 transition-all duration-300">

      <!-- 1. PRESENTACIÓN *********************************** -->
      <Content
        id="presentacion"
        tagline="Presentación"
        title="Alberto Jiménez, PhD"
        subtitle="Director del Postdoctorado"
        items={[
          {
            title: 'Programa en extenso',
            icon: 'tabler:download',
            callToAction: {
              text: 'Descargar el Programa en Extenso',
              href: 'https://drive.usercontent.google.com/download?id=1BvjHpeuctXB0sxdbLSwWepcPrnV5GwrM&export=download',
              variant: 'primary',
            },
          },
        ]}
        image={{
          src: '~/assets/images/users/fvi-alberto-jimenez.webp',
          alt: 'Alberto Jiménez, PhD - Director del Postdoctorado en Ciencias Aplicadas al Medio Ambiente',
        }}
      >
        <Fragment slot="content">
          <h3 class="text-xl font-semibold tracking-tight dark:text-white mb-2">
            Los problemas ambientales requieren <span class="text-primary">soluciones eficaces e innovadoras en los distintos ámbitos del medio ambiente</span>.
          </h3>
          <p class="pb-1">El incremento del impacto de las actividades humanas sobre el planeta, está provocando la pérdida del capital natural que soporta nuestro bienestar y las posibilidades futuras de desarrollo.</p>
          <p class="text-md pb-1">Las ciencias ambientales, constituyen una disciplina científica cuyo objeto es analizar la naturaleza y sus relaciones con el ser humano, aportando soluciones a los problemas de sostenibilidad, uno de los mayores desafíos actuales de las sociedades modernas.</p>
          <p class="text-md pb-1">El programa de Postdoctorado en Ciencias aplicadas al Medio Ambiente pretende mejorar nuestra comprensión del cambio ambiental global, la naturaleza y causas de los problemas ambientales. Además, estudia políticas, estrategias y tecnologías para fomentar una transición hacia una economía sostenible. Para ello, se complementará la formación de los postdoc con una serie de asignaturas obligatorias propuestas en la programación vigente, elaboradas con la asistencia técnica de profesionales PhD provenientes de institutos académicos y ONGs especializadas en cuestiones ambientales a escala internacional.</p>
          <p class="text-md pb-1">Los invitamos a ser parte de este desafío.</p>
        </Fragment>

        <Fragment slot="bg">
          <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
        </Fragment>
      </Content>

      <!-- 2. EL POSTDOCTORADO ******************************* -->
      <Features2
        id="el-postdoctorado"
        tagline="El Postdoctorado"
        title="¿Por qué hacer el postdoctorado?"
        subtitle='El Programa de <span class="text-primary font-semibold">Posdoctorado en</span> <span class="text-secondary font-semibold">Ciencias Aplicadas al Medio Ambiente</span> busca fortalecer la investigación científica sobre la relación entre la naturaleza y el ser humano, promoviendo soluciones sostenibles aplicables en la administración, la empresa y la industria. Dirigido a doctores de toda Iberoamérica y abierto a diversas disciplinas, el programa tiene una duración de <strong>seis meses</strong> a <strong>un año</strong> e incluye un plan de actividades cuyo resultado esperado es la publicación de un artículo arbitrado por jurados —uno de ellos internacional— y la presentación de un informe que evidencie el cumplimiento de las tareas previstas.'
        columns={2}
        items={[
          {
            title: 'Objetivos del Programa',
            description:
              'El Programa de <span class="text-primary font-semibold">Posdoctorado en</span> <span class="text-secondary font-semibold">Ciencias Aplicadas al Medio Ambiente</span>, se orientará de modo particular a: <ul class="list-disc ml-6 mt-2 space-y-1 text-muted"><li>Crear una plataforma para la discusión y el análisis del conocimiento en el ámbito medioambiental desde una visión global de los problemas ecológicos, la economía, los recursos naturales, el medio ambiente y la sostenibilidad.</li><li>Integrar especialistas latinoamericanos de alto perfil en un foro académico de medio ambiente que estudie políticas, estrategias y tecnologías para fomentar una transición hacia una economía sostenible.</li><li>Realizar investigación exhaustiva sobre tecnologías limpias de producción de energía, así como, sus implicaciones en el desarrollo sostenible, la ingeniería aplicada al desarrollo de proyectos y las soluciones técnicas en el ámbito de las energías renovables.</li><li>Presentar a la comunidad científica en México y Latinoamérica, conocimientos técnicos y herramientas de gestión necesarias para abordar, desde una visión multidisciplinar, cualquier proyecto empresarial o industrial con repercusión en el medio ambiente, dentro del marco de una economía social y sostenible.</li></ul>',
            icon: 'tabler:circle-plus',
          },
          {
            title: 'Perfil del destinatario',
            description:
              'El programa está dirigido a: <ul class="list-disc ml-6 mt-2 space-y-1 text-muted"><li>Doctores de universidades extranjeras y nacionales graduados en ecología global, biodiversidad, ciencias de la tierra o una disciplina relacionada, que persigan desarrollar un proyecto de investigación novedoso cuyo objeto sea analizar la naturaleza y sus relaciones con el ser humano.</li><li>Doctores de toda Iberoamérica y de cualquier disciplina, que posean especial interés en temas de sustentabilidad ambiental y que busquen desarrollar un proyecto de investigación en relación a dichos temas o se desempeñen laboralmente en áreas vinculadas.</li><li>Docentes, profesionales, asesores e investigadores locales, nacionales e internacionales con título doctoral, que muestren interés por la temática del ambiente y el desarrollo sustentable.</li><li>Profesionales recién doctorados especialmente motivados en formarse y/o profundizar en el paradigma ambiental como nueva forma de abordar la realidad y en el desarrollo sustentable como desafío a alcanzar.</li><li>Funcionarios y/o responsables de las políticas públicas a nivel local, regional o nacional en esta área o afines, que hayan obtenido su doctorado en alguna institución de reconocido prestigio.</li><li>Doctores que ejerzan la docencia y/o educadores en general interesados en la formación transdisciplinaria, el enfoque holístico y la mirada integral que el ambiente requiere.</li></ul>',
            icon: 'tabler:users',
          },
        ]}
      />

      <!-- 3. MODALIDADES -->
      <Modalidades />

      <!-- 4. ESTRUCTURA -->
      <Estructura />

      <!-- 5. ASIGNATURAS ************************************ -->
      <HeroSection
        id="asignaturas"
        tagline="Asignaturas"
        title="Asignaturas de la Programación"
        image={{
          src: '~/assets/images/postdocs/fvi_postDoc-CAMA-Asignatura.webp',
          alt: 'Asignaturas del programa de Posdoctorado en Ciencias Aplicadas al Medio Ambiente',
        }}
      >
        <Fragment slot="bg">
          <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
        </Fragment>
        <Fragment slot="subtitle">
          Son asignaturas obligatorias propuestas en la programación vigente, y a la vez es vinculante con el <span class="text-primary font-semibold">Trabajo Final de Investigación</span> - <span class="text-primary font-semibold">TFI</span>, por cuanto el postDoc deberá escoger una de las asignaturas de la programación y
          desarrollar algún aspecto que le resulte de interés.
        </Fragment>
      </HeroSection>

      <!-- 6. CÓMO SE ESTUDIA? -->
      <ComoSeEstudia />

      <!-- 7. CALUSTRO *************************************** -->
      <Content
        id="claustro"
        tagline="Claustro"
        title="Claustro Académico"
        items={[
          {
            title: 'Staff académico especializado',
            description:
              'El programa cuenta con un equipo de alto nivel, conformado por docentes universitarios e investigadores expertos en cada materia de conocimiento.',
            icon: 'tabler:users-group',
          },
          {
            title: 'Profesionales en activo',
            description:
              'Participan especialistas provenientes de la administración pública y de la empresa privada, aportando experiencia práctica en la gestión de proyectos.',
            icon: 'tabler:briefcase',
          },
          {
            title: 'Colaboración institucional',
            description:
              'Se suman profesionales de primer nivel de empresas, organismos oficiales e instituciones, directamente implicados en las áreas de conocimiento que abarca el posdoctorado.',
            icon: 'tabler:building',
          },
        ]}
        image={{
          src: '~/assets/images/fvi-claustro-academico.webp',
          alt: 'Claustro académico de Fondo Verde',
        }}
      >
        <Fragment slot="bg">
          <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
        </Fragment>
      </Content>
      <!-- Miembros del claustro -->
      {
        ['alberto-jimenez', 'angel-guillemes', 'loraine-giraud', 'gonzalo-fuente', 'erick-brenes'].map((id) => (
          <FacultyMember {...faculty[id]}>
            <Fragment slot="bg">
              <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark" />
            </Fragment>
          </FacultyMember>
        ))
      }

      <!-- 8. CERTIFICACIÓN ********************************** -->
      <Steps
        id="certificacion"
        tagline="Certificación"
        title="Evaluación y certificación"
        subtitle="Una vez cumplido y evaluado el Informe del Plan de Actividades y superado el Trabajo Final de Investigación, se expedirá un <strong>Diploma que acredite haber cursado el Programa de Postdoctorado</strong>."
        items={[
          {
            title: 'Diploma Oficial <br> <span class="font-normal">y Reconocimiento Institucional</span>',
            description: `El Diploma de Postdoctorado es expedido por <strong>Fondo Verde</strong>, inscrito en el Registro de Entidades Colaboradoras de la Junta de Castilla y León (España), en materia de Formación Profesional Ocupacional, con número <strong>11001</strong>.`,
            icon: 'tabler:certificate',
          },
          {
            title: 'Apostillado <br> <span class="font-normal">y Validez Internacional del Diploma</span>',
            description:
              'Desde España se realiza el proceso de apostillado por la Haya y la legitimación de firmas para que no tenga problemas a la hora de presentar el Diploma en un país fuera de España.',
            icon: 'tabler:certificate',
          },
        ]}
        classes={{ container: 'max-w-4xl' }}
      />
      <Features2
        columns={2}
        items={[
          {
            title: 'Requisitos para la Certificación PMPA™',
            description:
              'Los participantes que pretendan obtener la <strong class="text-primary">Certificación PMA™</strong> - Profesional en Medio Ambiente, categorías <strong class="text-primary">PMA™ Sénior</strong>, <strong class="text-primary">PMA™ Semi-Sénior</strong> y/o <strong class="text-primary">PMA™ Júnior</strong>, en función de su nivel de experiencia tienen que acreditar los requisitos de certificación relacionados con la credencial seleccionada.',
            icon: 'tabler:certificate-2',
          },
          {
            title: 'Licencia como Instructor PMPA™',
            description:
              'Los candidatos que acrediten que sus actuaciones han alcanzado un gran prestigio a nivel nacional e internacional, pueden postularse a la <strong class="text-primary">Certificación PMA™ Emérito</strong>, sufragando los derechos de licencia.',
            icon: 'tabler:certificate-2',
          },
        ]}
        classes={{ container: 'max-w-4xl' }}
      />

      <!-- 9. BECAS -->
      <Becas />

      <!-- 10. CÓMO APLICAR? -->
      <ComoAplicar />

      <!-- 11. INSCRIPCIÓN Y TASAS -->
      <InscripcionTasas />

      <!-- 12. PAGOS -->
      <Pagos />

      <!-- 13. SOLICITUDES -->
      <Solicitudes />

    </div>
  </div>
</Layout>
