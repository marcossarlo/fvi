---
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Features3 from '~/components/widgets/Features3.astro';
import Steps from '~/components/widgets/Steps.astro';
import Steps2 from '~/components/widgets/Steps2.astro';
import Stats from '~/components/widgets/Stats.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import WidgetWrapper from '~/components/ui/WidgetWrapper.astro';
import Layout from '~/layouts/PageLayout.astro';
import Features2 from '~/components/widgets/Features2.astro';

const metadata = {
    title: 'Posdoctorado en Gestión y Gobernanza de Proyectos Ambientales',
    description:
    'Programa de Posdoctorado en Gestión y Gobernanza de Proyectos Ambientales de Fondo Verde Institute: presentación, modalidades, estructura, asignaturas, claustro, certificación, becas, aplicación, inscripción, pagos y solicitudes.',
    keywords:
    'posdoctorado, gestión y gobernanza de proyectos ambientales, Fondo Verde Institute, modalidades, estructura, asignaturas, claustro, certificación, becas, inscripción, pagos, solicitudes',
};

const tabs = [
    { label: '1. Presentación', id: 'presentacion' },
    { label: '2. El Postdoctorado', id: 'el-postdoctorado' },
    { label: '3. Modalidades', id: 'modalidades' },
    { label: '4. Estructura', id: 'estructura' },
    { label: '5. Asignaturas', id: 'asignaturas' },
    { label: '6. ¿Cómo se estudia?', id: 'como-se-estudia' },
    { label: '7. Claustro', id: 'claustro' },
    { label: '8. Certificación', id: 'certificacion' },
    { label: '9. Becas', id: 'becas' },
    { label: '10. ¿Cómo aplicar?', id: 'como-aplicar' },
    { label: '11. Inscripción', id: 'inscripcion' },
    { label: '12. Pagos', id: 'pagos' },
    { label: '13. Solicitudes', id: 'solicitudes' },
];
---

<Layout metadata={metadata}>
  <!-- Hero ********************************************** -->
  <Hero
      tagline="PostDoc"
      image={{
          src: 'https://images.unsplash.com/photo-1504711434969-e33886168f5c?q=80&w=1600&auto=format&fit=crop',
          alt: 'Posdoctorado en Gestión y Gobernanza de Proyectos Ambientales',
      }}
  >
      <Fragment slot="title">
          Posdoctorado en
          <span class="text-primary dark:text-accent"> Gestión y Gobernanza de Proyectos Ambientales</span>
      </Fragment>

      <Fragment slot="subtitle">
          La cuestión del ambiente y la sustentabilidad se ha transformado en un verdadero <strong>cambio de paradigma</strong> en
          las actividades de desarrollo y organización.
      </Fragment>
  </Hero>

  <!-- Datos clave *************************************** -->
  <Stats
  stats={[
      { amount: '6–12', title: 'Meses de duración', icon: 'tabler:calendar' },
      { amount: '100%', title: 'Modalidad online', icon: 'tabler:device-laptop' },
      { amount: '3 Jun 2026', title: 'Próximo inicio', icon: 'tabler:calendar-event' },
      { amount: 'PhD', title: 'Requisito de acceso', icon: 'tabler:certificate' },
  ]}
  >
  <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
  </Fragment>
  </Stats>

  <!-- Índice de secciones ******************************* -->
  <WidgetWrapper containerClass="max-w-6xl mx-auto" id="indice-secciones">
      <h2 class="text-2xl md:text-3xl font-bold tracking-tight text-primary dark:text-accent">Secciones del programa</h2>
      <p class="mt-3 text-slate-700 dark:text-slate-300">
          Explora las secciones clave del Programa de Posdoctorado en Gestión y Gobernanza de Proyectos Ambientales para conocer su estructura, contenido y oportunidades.
      </p>
      <nav aria-label="Secciones del posdoctorado" class="mt-6">
          <ul class="grid gap-3 md:grid-cols-2 lg:grid-cols-3">
          {
              tabs.map((tab) => (
              <li>
                  <a
                  href={`#${tab.id}`}
                  class="group flex items-center justify-between rounded-lg border border-slate-200 dark:border-slate-700 px-4 py-3 text-sm md:text-base text-slate-700 dark:text-slate-200 hover:border-primary hover:text-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary transition-colors"
                  >
                  <span>{tab.label}</span>
                  <span class="text-primary" aria-hidden="true">→</span>
                  </a>
              </li>
              ))
          }
          </ul>
      </nav>
  </WidgetWrapper>

  <!-- 1. PRESENTACIÓN *********************************** -->
  <Content
      id="presentacion"
      tagline="Presentación"
      title="Ángel Guillemes Peira, PhD"
      subtitle="Director del Postdoctorado"
      items={[
          {
          title: 'Cambio de paradigma ambiental ',
          description:
              'La sustentabilidad se ha convertido en un eje transversal e intersectorial, imprescindible para el desarrollo y la organización de proyectos complejos.',
          icon: 'tabler:refresh',
          },
          {
          title: 'Evaluación y formación en el posdoctorado',
          description:
              'Se implementa un nuevo procedimiento de evaluación para identificar talentos capaces de gerenciar proyectos ambientales sustentables, complementado con asignaturas obligatorias de la programación vigente.',
          icon: 'tabler:checklist',
          },
          {
          title: 'Respaldo institucional pionero',
          description:
              'La formación cuenta con la asistencia técnica de la Fundación CEPA y FLACAM / Cátedra UNESCO para el Desarrollo Sustentable, instituciones con trayectoria desde 1974 en la capacitación de proyectistas ambientales en Latinoamérica.',
          icon: 'tabler:building-bank',
          },
          {
              title: 'Programa en extenso',
              icon: 'tabler:download',
              callToAction: {
                  text: 'Descargar el Programa en Extenso',
                  href: 'https://drive.google.com/uc?export=download&id=12gbTyeRWL_XASSyWahhuL2qptXskqyzL',
                  variant: 'primary',
              },
          }
      ]}
      image={{
          src: '~/assets/images/users/fvi-angel-guillemes.webp',
          alt: 'Ángel Guillemes Peira, PhD - Director del Postdoctorado en Gestión y Gobernanza de Proyectos Ambientales',
      }}
      >
      <Fragment slot="content">
          <h3 class="text-xl font-medium tracking-tight dark:text-white mb-2">La realidad actual requiere el desarrollo de proyectos ambientales multipropósitos</h3>
      </Fragment>

      <Fragment slot="bg">
          <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
      </Fragment>
  </Content>

  <!-- 2. EL POSTDOCTORADO ******************************* -->
  <Features2
    id="el-postdoctorado"
    tagline="El Postdoctorado"
    title="¿Por qué hacer el postdoctorado?"
    subtitle="El <strong>Posdoctorado en Gestión y Gobernanza de Proyectos Ambientales</strong> está dirigido a doctores de toda Iberoamérica y busca fortalecer la producción científica en torno a la sustentabilidad. Con una duración de <strong>6 meses</strong> a <strong>1 año</strong>, el programa exige la realización de un plan de actividades cuyo resultado sea la publicación de un artículo arbitrado por jurados —uno de ellos internacional— y la presentación de un informe final, consolidando así la formación en la gestión de proyectos ambientales complejos."
    columns={2}
    items={[      
      {
        title: 'Objetivos del Programa',
        description:
          'El Programa se orientará de modo particular a: <ul class="list-disc ml-6 mt-2 space-y-1 text-muted"><li>Promover una instancia de reflexión crítica en el nuevo paradigma ambiental que permita estimular el compromiso y la acción propiamente dicha, para multiplicar la cantidad y calidad de los proyectos, mediante la concepción, formulación y gestión de proyectos sustentables concretos.</li><li>Introducir al postdoc en el campo de la gestión y gobernanza de proyectos ambientales con una metodología innovadora y transdiciplinaria de alto impacto y nivel de éxito en toda Latinoamérica.</li><li>Abrir nuevas perspectivas para abordar estrategias de articulación y actuación en México y Latinoamérica, en materia de desarrollo sustentable de alcance en las políticas públicas y privadas.</li><li>Generar un clima de reflexión, de co-construcción de conocimiento y de formulación de propuestas concretas vinculadas al ambiente y al desarrollo sustentable en Latinoamérica.</li></ul>',
        icon: 'tabler:circle-plus',
      },
      {
        title: 'Perfil del destinatario',
        description:
          'El Programa está dirigido a: <ul class="list-disc ml-6 mt-2 space-y-1 text-muted"> \
            <li>Doctores de universidades extranjeras y nacionales graduados en ecología global, biodiversidad, ciencias de la tierra o una disciplina relacionada, que persigan desarrollar un proyecto de investigación novedoso en el campo de la gestión y gobernanza de proyectos ambientales.</li> \
            <li>Doctores de toda Iberoamérica y de cualquier disciplina, que posean especial interés en temas de sustentabilidad ambiental y que busquen desarrollar un proyecto de investigación en relación a dichos temas o se desempeñen laboralmente en áreas vinculadas.</li> \
            <li>Docentes, profesionales, asesores e investigadores locales, nacionales e internacionales con título doctoral, que muestren interés por la temática del ambiente y el desarrollo sustentable.</li> \
            <li>Profesionales recién doctorados especialmente motivados en formarse y/o profundizar en el paradigma ambiental como nueva forma de abordar la realidad y en el desarrollo sustentable como desafío a alcanzar.</li> \
            <li>Funcionarios y/o responsables de las políticas públicas a nivel local, regional o nacional en esta área o afines, que hayan obtenido su doctorado en alguna institución de reconocido prestigio.</li> \
            <li>Doctores que ejerzan la docencia y/o educadores en general interesados en la formación transdisciplinaria, el enfoque holístico y la mirada integral que el ambiente requiere.</li> \
          </ul>',
        icon: 'tabler:users',
      }
    ]}
  />

  <!-- 3. MODALIDADES ************************************ -->
  <Features2
      id="modalidades"
      tagline="Modalidades"
      title="Modalidades y Condiciones del Postdoctorado"
      subtitle="El programa ofrece dos tipos de instancias posdoctorales:"
  >
    <Fragment slot="bg">            
        <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features2>

  <!-- Modalidad Intensivo -->
  <Steps      
    title='Intensivo <span class="text-xl font-light">(6 meses)</span>'
    tagline='Modalidad'
    subtitle="<strong>Para redacción de publicaciones (6 meses).</strong> <br />
    El objetivo de esta modalidad es apoyar a los/las postdoc a que puedan terminar publicaciones vinculadas al ambiente y al desarrollo sustentable. <br />La/el postdoc debe cumplir con las siguientes condiciones:"
    bg='<div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>'   
    items={[
      {
        title: 'Duración',
        description:
          'Seis (06) meses de actividades planificadas.',
        icon: 'tabler:clock',
      },
      {
        title: 'Producto Final',
        description:
          'El producto final debe ser un artículo publicable en una revista indexada (en inglés o en castellano).',
        icon: 'tabler:article',
      },
      {
        title: 'Resultados de una Investigación Original',
        description:
          'El artículo debe incluir resultados de una investigación original que avance en la definición de un nuevo paradigma de sociedad, que aborde dicha problemática desde la perspectiva integral e integradora del desarrollo sustentable.',
        icon: 'tabler:bulb',
      },
      {
        title: 'Resultados',
        description:
          'Presentar avances y resultados de su investigación.',
        icon: 'tabler:check',
      }
    ]}
  />
  <!-- Modalidad Flexible -->
  <Steps
    title='Flexible <span class="text-xl font-light">(12 meses)</span>'
    tagline='Modalidad'
    subtitle='<strong>Para desarrollar algún aspecto que le resulte de interés (12 meses)</strong> <br />
    La/ el postdoc debe cumplir con las siguientes condiciones:'
    bg='<div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>'
    items={[
      {
        title: 'Duración',
        description:
        '<strong>Máximo 6 meses</strong> de investigación de campo. La/ el postdoc deberá escoger una de las <strong>asignaturas de la programación</strong> y desarrollar algún aspecto que le resulte de interés.<br /> <strong>Mínimo 6 meses</strong> de actividades planificadas (después del trabajo de campo).',
        icon: 'tabler:clock',
      },
      {
        title: 'Producto final',
        description:
          'El producto final debe ser un artículo enviado a una revista de investigación indexada.',
        icon: 'tabler:article',
      },
      {
        title: 'Participación',
        description:
          'Participar de las distintas actividades de docencia e iniciativas académicas.',
        icon: 'tabler:books',
      },
      {
        title: 'Resultados',
        description:
          'Presentar avances y resultados de su investigación.',
        icon: 'tabler:check',
      }
    ]}
  />

  <!-- 4. ESTRUCTURA ************************************* -->
  <Features2
    id="estructura"
    tagline="Estructura"
    title="Estructura del Programa"
    subtitle='El Programa de Postdoctorado tiene una duración mínima de <strong>6 meses en su versión intensiva</strong> y máxima de <strong>1 año en su formato flexible</strong>, ampliable hasta 1 trimestre.'
  />

  <Steps2
    title='Actividades'
    subtitle='Las actividades del/la postDoc, giran alrededor de los siguientes <strong>cinco</strong> aspectos fundamentales:'
    colLeft="md:w-1/5"
    colRight="md:w-4/5"
    items={[
      {
        title: 'Plan de Trabajo Postdoctoral.',
        description:
          'Consiste en la realización de un plan de actividades asignadas a los doctores dentro del programa y/o proyecto de investigación propuesto. Las tareas programadas se realizan bajo la supervisión de un director designado a tal efecto.',
        icon: 'tabler:number-1',
      },
      {
        title: 'Asignaturas de la programación.',
        description:
          'Son asignaturas obligatorias propuestas en la programación vigente y se compone de varias áreas temáticas que fomentan la colaboración transnacional en muy diferentes campos de estudio, con enfoque en el avance de la ciencia y la investigación.',
        icon: 'tabler:number-2',
      },
      {
        title: 'Trabajo Final de Investigación – TFI.',
        description:
          'En lo referente al TFI, los alumnos identifican una de las asignaturas de la programación y desarrollan algún aspecto que le resulte de interés y cuyo resultado debe ser la publicación de un artículo en una revista de nivel académico acorde a los requisitos exigidos en publicaciones de nivel internacional.',
        icon: 'tabler:number-3',
      },
      {
        title: 'Informe final avalado.',
        description:
          'Consiste en la presentación de un informe del cumplimiento de las tareas previstas en el plan de trabajo propuesto y avalado por su Director.',
        icon: 'tabler:number-4',
      },
      {
        title: 'Defensa del TFI.',
        description:
          'La defensa de la investigación es un acto público y consistirá en la exposición y defensa del trabajo ante un jurado seleccionado por el Comité de Posdoctorado. Los doctores presentes pueden formular cuestiones.',
        icon: 'tabler:number-5',
      }
    ]}
  />
  <Steps
    subtitle="La/ el postdoc deberá cumplir, durante su estancia, con algunas de las tareas que se detallan:"
    items={[
      {
        title: '<span class="text-primary">POSTDOC INTENSIVO</span>',
        description: '<ol><li><strong>1.</strong> Cursar una serie de asignaturas de la programación.</li><li><strong>2.</strong> Exposición sobre el tema de investigación propuesto.</li><li><strong>3.</strong> Colaboración del doctor como jurado de tesis</li></ol>',
        icon: 'tabler:school',
      },
      {
        title: '<span class="text-muted">POSTDOC FLEXIBLE</span>',
        description: 'Además de <strong>1</strong>, <strong>2</strong> y <strong>3</strong>: <ol><li><strong>4.</strong> Realizar actividades de investigación de campo.</li><li><strong>5.</strong> Impartir conferencias en las materias de su interés.</li><li><strong>6.</strong> Participación en pasantías, seminarios o congresos.</li></ol>',
        icon: 'tabler:school',
      },
      {
        title: '<span class="text-secondary">TRABAJO FINAL</span>',
        description: 'Defensa del Trabajo Final de Investigación - TFI.',
        icon: 'tabler:school',
      },
      {
        description: '<span class="font-semibold text-accent">La/ el postdoc también será responsable de fomentar la investigación ecológica global dentro de nuestro instituto, por ejemplo, a través del desarrollo de actividades conjuntas e interinstitucionales.</span>',
      }
    ]}
  />

  <!-- 5. Asignaturas ************************************ -->
  <Content
    id="asignaturas"
    tagline="5. Asignaturas"
    title="Asignaturas"
    items={[
      {
        title: 'Seminarios de investigación',
        description: 'Espacios orientados al análisis crítico y actualización científica en sostenibilidad ambiental.',
        icon: 'tabler:search',
      },
      {
        title: 'Módulos de gestión y gobernanza',
        description: 'Componentes académicos enfocados en diseño, gestión y evaluación de proyectos ambientales.',
        icon: 'tabler:hierarchy',
      },
      {
        title: 'Contenido detallado en migración',
        description:
          'La malla de asignaturas específica de esta ficha está en proceso de consolidación desde el Joomla original para publicar el detalle final.',
        icon: 'tabler:info-circle',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?q=80&w=1200&auto=format&fit=crop',
      alt: 'Plan de asignaturas del programa',
    }}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- 6. ¿Cómo se estudia? ****************************** -->
  <Content
    id="como-se-estudia"
    tagline="6. ¿Cómo se estudia?"
    title="¿Cómo se estudia?"
    isReversed
    items={[
      {
        title: 'Campus Virtual de Fondo Verde',
        description:
          'Todos los programas se desarrollan a través del Campus Virtual de Fondo Verde (<a href="https://www.fondoverdeopen.net/" target="_blank" rel="noopener noreferrer" class="text-primary hover:text-secondary underline underline-offset-2">fondoverdeopen.net</a>).',
        icon: 'tabler:device-laptop',
      },
      {
        title: 'Recursos didácticos multimedia',
        description:
          'Acceso permanente a contenidos en formato digital, casos prácticos, videos y materiales de apoyo.',
        icon: 'tabler:video',
      },
      {
        title: 'Interacción y acompañamiento',
        description:
          'Canales de chat, foros y mensajería para consultas con tutor y comunicación con otros participantes.',
        icon: 'tabler:messages',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1516321318423-f06f85e504b3?q=80&w=1200&auto=format&fit=crop',
      alt: 'Estudio online en campus virtual',
    }}
  />

  <!-- 7. Claustro *************************************** -->
  <Content
    id="claustro"
    tagline="7. Claustro"
    title="Claustro docente"
    subtitle="Equipo académico con experiencia en investigación, dirección y evaluación de proyectos ambientales."
    items={[
      {
        title: 'Docentes e investigadores especialistas',
        description:
          'La ficha de claustro específica para este postdoctorado se está homologando para mostrar perfiles completos durante la migración.',
        icon: 'tabler:users-group',
      },
      {
        title: 'Dirección académica',
        description:
          'Las actividades postdoctorales se realizan bajo la supervisión de un director designado para el seguimiento del plan de investigación.',
        icon: 'tabler:user-check',
      },
      {
        title: 'Consulta temporal del profesorado',
        description:
          'Mientras se integra el detalle final del claustro, puedes revisar el equipo académico institucional en la sección correspondiente.',
        icon: 'tabler:external-link',
        callToAction: {
          text: 'Ver Profesorado e Investigación',
          href: '/profesorado-investigacion',
        },
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1523240795612-9a054b0db644?q=80&w=1200&auto=format&fit=crop',
      alt: 'Claustro académico',
    }}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Content>

  <!-- 8. Certificación ********************************** -->
  <Features3
    id="certificacion"
    tagline="8. Certificación"
    title="Evaluación y certificación"
    subtitle="Una vez cumplido y evaluado el Informe del Plan de Actividades y superado el Trabajo Final de Investigación, se expide el Diploma del Programa de Postdoctorado."
    columns={3}
    items={[
      {
        title: 'Artículo científico arbitrado',
        description:
          'El proceso considera publicación arbitrada por dos jurados académicos, uno de carácter internacional.',
        icon: 'tabler:article',
      },
      {
        title: 'Diploma de Postdoctorado',
        description:
          'Diploma expedido por Fondo Verde, inscrito en el Registro de Entidades Colaboradoras de la Junta de Castilla y León (España), número 11001.',
        icon: 'tabler:certificate',
      },
      {
        title: 'Respaldo institucional',
        description:
          'Alineado con el esquema académico y de reconocimiento internacional del Instituto.',
        icon: 'tabler:building-bank',
      },
    ]}
  />

  <!-- 9. Becas ****************************************** -->
  <Features3
    id="becas"
    tagline="9. Becas"
    title="Becas"
    subtitle="Fondo Verde dispone de Programa de Becas para ciudadanos europeos y latinoamericanos con cobertura referencial de hasta el 50% según convocatoria."
    columns={3}
    items={[
      {
        title: 'Becas Fondo Verde',
        description: 'Convocatorias para facilitar el acceso a programas de posgrado en modalidad online.',
        icon: 'tabler:award',
      },
      {
        title: 'Financiamiento',
        description: 'Opciones y lineamientos de apoyo económico publicados en la sección de becas.',
        icon: 'tabler:pig-money',
      },
      {
        title: 'Cómo aplicar a beca',
        description: 'Requisitos y pasos de postulación disponibles en la sección oficial de becas.',
        icon: 'tabler:file-search',
      },
    ]}
  >
    <Fragment slot="bg">
      <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
    </Fragment>
  </Features3>

  <!-- 10. ¿Cómo aplicar? ******************************** -->
  <Steps
    id="como-aplicar"
    tagline="10. ¿Cómo aplicar?"
    title="¿Cómo aplicar?"
    subtitle="Todo candidato debe cumplir con los reglamentos, políticas y criterios vigentes de admisión establecidos por la institución."
    items={[
      {
        title: 'Paso 1 · Revisar requisitos',
        description: 'Verificar condiciones académicas de acceso y documentación requerida.',
        icon: 'tabler:list-details',
      },
      {
        title: 'Paso 2 · Preparar expediente',
        description: 'Organizar documentos académicos y de identificación solicitados.',
        icon: 'tabler:file-upload',
      },
      {
        title: 'Paso 3 · Enviar solicitud',
        description: 'Remitir la postulación por los canales institucionales habilitados.',
        icon: 'tabler:send',
      },
      {
        title: 'Paso 4 · Seguimiento de admisión',
        description: 'Esperar revisión académica y respuesta formal del proceso de admisión.',
        icon: 'tabler:clock-check',
      },
    ]}
  />

  <!-- 11. Inscripción *********************************** -->
  <Content
    id="inscripcion"
    tagline="11. Inscripción"
    title="Inscripción"
    items={[
      {
        title: 'Apertura de inscripciones',
        description:
          'Las inscripciones se gestionan por convocatoria. El inicio referencial de esta edición es el 3 de junio de 2026.',
        icon: 'tabler:calendar-event',
      },
      {
        title: 'Validación documental',
        description:
