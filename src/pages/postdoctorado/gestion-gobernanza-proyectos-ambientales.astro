---
import HeroPrograms from '~/components/widgets/HeroPrograms.astro';
import Content from '~/components/widgets/Content.astro';
import HeroSection from '~/components/widgets/HeroSection.astro';
import Steps from '~/components/widgets/Steps.astro';
import Layout from '~/layouts/PageLayout.astro';
import Features2 from '~/components/widgets/Features2.astro';
import FacultyMember from '~/components/widgets/FacultyMember.astro';
import { faculty } from '~/data/faculty';
import DatosEstadisticas from '~/components/postdoctorado/DatosEstadisticas.astro';
import Modalidades from '~/components/postdoctorado/Modalidades.astro';
import Estructura from '~/components/postdoctorado/Estructura.astro';
import ComoSeEstudia from '~/components/postdoctorado/ComoSeEstudia.astro';
import Becas from '~/components/postdoctorado/Becas.astro';
import ComoAplicar from '~/components/postdoctorado/ComoAplicar.astro';
import InscripcionTasas from '~/components/postdoctorado/InscripcionTasas.astro';
import Pagos from '~/components/postdoctorado/Pagos.astro';
import Solicitudes from '~/components/postdoctorado/Solicitudes.astro';
import ProgramTOC from '~/components/widgets/ProgramTOC.astro';

const metadata = {
  title: 'Posdoctorado en Gestión y Gobernanza de Proyectos Ambientales',
  description:
    'Fortalece tu producción científica con el Posdoctorado en Gestión y Gobernanza de Proyectos Ambientales. Un programa transdisciplinario de 6 a 12 meses, orientado a doctores que buscan liderar el cambio de paradigma hacia la sustentabilidad en Iberoamérica.',
  keywords:
    'posdoctorado, gestión y gobernanza de proyectos ambientales, sustentabilidad, gobernanza ambiental, Fondo Verde Institute, investigación posdoctoral, FLACAM, UNESCO, doctores Iberoamérica',
};

const tabs = [
  { label: '1. Presentación', id: 'presentacion' },
  { label: '2. El Postdoctorado', id: 'el-postdoctorado' },
  { label: '3. Modalidades', id: 'modalidades' },
  { label: '4. Estructura', id: 'estructura' },
  { label: '5. Asignaturas', id: 'asignaturas' },
  { label: '6. ¿Cómo se estudia?', id: 'como-se-estudia' },
  { label: '7. Claustro', id: 'claustro' },
  { label: '8. Certificación', id: 'certificacion' },
  { label: '9. Becas', id: 'becas' },
  { label: '10. ¿Cómo aplicar?', id: 'como-aplicar' },
  { label: '11. Inscripción', id: 'inscripcion' },
  { label: '12. Pagos', id: 'pagos' },
  { label: '13. Solicitudes', id: 'solicitudes' },
];
---

<Layout metadata={metadata} showSecondaryNav={false}>
  <!-- Hero ********************************************** -->
  <HeroPrograms
    tagline="Convocatoria Abierta 2026"
    subtitle="La cuestión del ambiente y la sustentabilidad se ha transformado en un verdadero <strong>cambio de paradigma</strong> en las actividades de desarrollo y organización."
    actions={[
      {
        variant: 'primary',
        text: 'Solicita información',
        href: '#',
        icon: 'tabler:mail-forward',
        class: '!bg-primary !border-primary !text-white hover:!bg-secondary hover:!border-secondary transition-colors duration-300',
      },
      {
        variant: 'secondary',
        text: 'Ver Folleto Académico',
        href: 'https://drive.google.com/uc?export=download&id=12gbTyeRWL_XASSyWahhuL2qptXskqyzL',
        icon: 'tabler:download',
        class: '!bg-transparent !text-white !border-[1px] !border-solid !border-white/50 hover:!bg-white/10 hover:!text-white hover:!border-white transition-all duration-300',
      },
    ]}
    image={{
      src: '~/assets/images/postdocs/fvi-postdoc-gestion-gobernanza-proyectos-ambientales.webp',
      alt: 'Turbinas eólicas y gestión de proyectos ambientales',
    }}
  >
    <Fragment slot="title">
      Posdoctorado en <br />
      <span class="text-primary dark:text-accent"> Gestión y Gobernanza <br />
        de Proyectos Ambientales</span>
    </Fragment>
  </HeroPrograms>

  <!-- Replaced DatosEstadisticas -->
      <DatosEstadisticas />  

  <div class="relative max-w-[100vw] overflow-x-hidden">
    <!-- Desktop Sidebar & Mobile Floating Pill -->
    <ProgramTOC tabs={tabs} />
    
    <!-- Main Content Wrapper that creates space for the Desktop Sidebar -->
    <div class="lg:ml-64 2xl:ml-[18rem] pb-24 lg:pb-0 transition-all duration-300">

      <!-- 1. PRESENTACIÓN *********************************** -->
      <Content
        id="presentacion"
        tagline="Presentación"
        title="Ángel Guillemes Peira, PhD"
        subtitle="Director del Postdoctorado"
        items={[
          {
            title: 'Cambio de paradigma ambiental ',
            description:
              'La sustentabilidad se ha convertido en un eje transversal e intersectorial, imprescindible para el desarrollo y la organización de proyectos complejos.',
            icon: 'tabler:refresh',
          },
          {
            title: 'Evaluación y formación en el posdoctorado',
            description:
              'Se implementa un nuevo procedimiento de evaluación para identificar talentos capaces de gerenciar proyectos ambientales sustentables, complementado con asignaturas obligatorias de la programación vigente.',
            icon: 'tabler:checklist',
          },
          {
            title: 'Respaldo institucional pionero',
            description:
              'La formación cuenta con la asistencia técnica de la Fundación CEPA y FLACAM / Cátedra UNESCO para el Desarrollo Sustentable, instituciones con trayectoria desde 1974 en la capacitación de proyectistas ambientales en Latinoamérica.',
            icon: 'tabler:building-bank',
          },
          {
            title: 'Programa en extenso',
            icon: 'tabler:download',
            callToAction: {
              text: 'Descargar el Programa en Extenso',
              href: 'https://drive.google.com/uc?export=download&id=12gbTyeRWL_XASSyWahhuL2qptXskqyzL',
              variant: 'primary',
            },
          },
        ]}
        image={{
          src: '~/assets/images/users/fvi-angel-guillemes.webp',
          alt: 'Ángel Guillemes Peira, PhD - Director del Postdoctorado en Gestión y Gobernanza de Proyectos Ambientales',
        }}
      >
        <Fragment slot="content">
          <h3 class="text-xl font-medium tracking-tight dark:text-white mb-2">
            La realidad actual requiere el desarrollo de proyectos ambientales multipropósitos
          </h3>
        </Fragment>

        <Fragment slot="bg">
          <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
        </Fragment>
      </Content>

      <!-- 2. EL POSTDOCTORADO ******************************* -->
      <Features2
        id="el-postdoctorado"
        tagline="El Postdoctorado"
        title="¿Por qué hacer el postdoctorado?"
        subtitle='El <span class="text-primary font-semibold">Posdoctorado en</span> <span class="text-secondary font-semibold">Gestión y Gobernanza de Proyectos Ambientales</span> está dirigido a doctores de toda Iberoamérica y busca fortalecer la producción científica en torno a la sustentabilidad. Con una duración de <strong>6 meses</strong> a <strong>1 año</strong>, el programa exige la realización de un plan de actividades cuyo resultado sea la publicación de un artículo arbitrado por jurados —uno de ellos internacional— y la presentación de un informe final, consolidando así la formación en la gestión de proyectos ambientales complejos.'
        columns={2}
        items={[
          {
            title: 'Objetivos del Programa',
            description:
              'El Programa se orientará de modo particular a: <ul class="list-disc ml-6 mt-2 space-y-1 text-muted"><li>Promover una instancia de reflexión crítica en el nuevo paradigma ambiental que permita estimular el compromiso y la acción propiamente dicha, para multiplicar la cantidad y calidad de los proyectos, mediante la concepción, formulación y gestión de proyectos sustentables concretos.</li><li>Introducir al postdoc en el campo de la gestión y gobernanza de proyectos ambientales con una metodología innovadora y transdiciplinaria de alto impacto y nivel de éxito en toda Latinoamérica.</li><li>Abrir nuevas perspectivas para abordar estrategias de articulación y actuación en México y Latinoamérica, en materia de desarrollo sustentable de alcance en las políticas públicas y privadas.</li><li>Generar un clima de reflexión, de co-construcción de conocimiento y de formulación de propuestas concretas vinculadas al ambiente y al desarrollo sustentable en Latinoamérica.</li></ul>',
            icon: 'tabler:circle-plus',
          },
          {
            title: 'Perfil del destinatario',
            description:
              'El Programa está dirigido a: <ul class="list-disc ml-6 mt-2 space-y-1 text-muted"> \
                <li>Doctores de universidades extranjeras y nacionales graduados en ecología global, biodiversidad, ciencias de la tierra o una disciplina relacionada, que persigan desarrollar un proyecto de investigación novedoso en el campo de la gestión y gobernanza de proyectos ambientales.</li> \
                <li>Doctores de toda Iberoamérica y de cualquier disciplina, que posean especial interés en temas de sustentabilidad ambiental y que busquen desarrollar un proyecto de investigación en relación a dichos temas o se desempeñen laboralmente en áreas vinculadas.</li> \
                <li>Docentes, profesionales, asesores e investigadores locales, nacionales e internacionales con título doctoral, que muestren interés por la temática del ambiente y el desarrollo sustentable.</li> \
                <li>Profesionales recién doctorados especialmente motivados en formarse y/o profundizar en el paradigma ambiental como nueva forma de abordar la realidad y en el desarrollo sustentable como desafío a alcanzar.</li> \
                <li>Funcionarios y/o responsables de las políticas públicas a nivel local, regional o nacional en esta área o afines, que hayan obtenido su doctorado en alguna institución de reconocido prestigio.</li> \
                <li>Doctores que ejerzan la docencia y/o educadores en general interesados en la formación transdisciplinaria, el enfoque holístico y la mirada integral que el ambiente requiere.</li> \
              </ul>',
            icon: 'tabler:users',
          },
        ]}
      />

      <!-- 3. MODALIDADES -->
      <Modalidades />

      <!-- 4. ESTRUCTURA -->
      <Estructura />

      <!-- 5. ASIGNATURAS ************************************ -->
      <HeroSection
        id="asignaturas"
        tagline="Asignaturas"
        title="Asignaturas de la Programación"
        image={{
          src: '~/assets/images/postdocs/fvi-postDoc-GGPA-Asignaturas.webp',
          alt: 'Asignaturas del programa de Posdoctorado en Gestión y Gobernanza de Proyectos Ambientales',
        }}
      >
        <Fragment slot="bg">
          <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
        </Fragment>
        <Fragment slot="subtitle">
          Son asignaturas obligatorias propuestas en la programación vigente, y a la vez es vinculante con el <span class="text-primary font-semibold">Trabajo Final de Investigación</span> - <span class="text-primary font-semibold">TFI</span>, por cuanto el postDoc deberá escoger una de las asignaturas de la programación y
          desarrollar algún aspecto que le resulte de interés.
        </Fragment>
      </HeroSection>

      <!-- 6. CÓMO SE ESTUDIA? -->
      <ComoSeEstudia />

      <!-- 7. CALUSTRO *************************************** -->
      <Content
        id="claustro"
        tagline="Claustro"
        title="Claustro Académico"
        items={[
          {
            title: 'Staff académico especializado',
            description:
              'El programa cuenta con un equipo de alto nivel, conformado por docentes universitarios e investigadores expertos en cada materia de conocimiento.',
            icon: 'tabler:users-group',
          },
          {
            title: 'Profesionales en activo',
            description:
              'Participan especialistas provenientes de la administración pública y de la empresa privada, aportando experiencia práctica en la gestión de proyectos.',
            icon: 'tabler:briefcase',
          },
          {
            title: 'Colaboración institucional',
            description:
              'Se suman profesionales de primer nivel de empresas, organismos oficiales e instituciones, directamente implicados en las áreas de conocimiento que abarca el posdoctorado.',
            icon: 'tabler:building',
          },
        ]}
        image={{
          src: '~/assets/images/fvi-claustro-academico.webp',
          alt: 'Claustro académico de Fondo Verde',
        }}
      >
        <Fragment slot="bg">
          <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
        </Fragment>
      </Content>
      <!-- Miembros del claustro -->
      {
        ['angel-guillemes', 'gonzalo-fuente', 'alberto-jimenez', 'erick-brenes'].map((id) => (
          <FacultyMember {...faculty[id]}>
            <Fragment slot="bg">
              <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark" />
            </Fragment>
          </FacultyMember>
        ))
      }

      <!-- 8. CERTIFICACIÓN ********************************** -->
      <Steps
        id="certificacion"
        tagline="Certificación"
        title="Evaluación y certificación"
        subtitle="Una vez cumplido y evaluado el Informe del Plan de Actividades y superado el Trabajo Final de Investigación, se expedirá un <strong>Diploma que acredite haber cursado el Programa de Postdoctorado</strong>."
        items={[
          {
            title: 'Diploma Oficial <br> <span class="font-normal">y Reconocimiento Institucional</span>',
            description: `El Diploma de Postdoctorado es expedido por <strong>Fondo Verde</strong>, inscrito en el Registro de Entidades Colaboradoras de la Junta de Castilla y León (España), en materia de Formación Profesional Ocupacional, con número <strong>11001</strong>.`,
            icon: 'tabler:certificate',
          },
          {
            title: 'Apostillado <br> <span class="font-normal">y Validez Internacional del Diploma</span>',
            description:
              'Desde España se realiza el proceso de apostillado por la Haya y la legitimación de firmas para que no tenga problemas a la hora de presentar el Diploma en un país fuera de España.',
            icon: 'tabler:certificate',
          },
        ]}
        classes={{ container: 'max-w-4xl' }}
      />
      <Features2
        columns={2}
        items={[
          {
            title: 'Requisitos para la Certificación PMPA™',
            description:
              'Los participantes que pretendan obtener la Certificación <strong>PMPA™</strong> - <strong>Profesional Mánager en Proyectos Ambientales</strong>, categorías <strong>PMPA™ Especialista</strong>, <strong>PMPA™ Experto</strong> y/o <strong>PMPA™ Eminencia</strong>, en función de su nivel de experiencia tienen que acreditar los requisitos de certificación relacionados con la credencial seleccionada.',
            icon: 'tabler:certificate-2',
          },
          {
            title: 'Licencia como Instructor PMPA™',
            description:
              'Con la obtención del certificado PMPA™ excepcionalmente podrán acreditarse como <strong>PMPA™ Instructor Network</strong> con licencia local y/o licencia internacional, superando etapas adicionales y sufragando los derechos de licencia.',
            icon: 'tabler:certificate-2',
          },
        ]}
        classes={{ container: 'max-w-4xl' }}
      />

      <!-- 9. BECAS -->
      <Becas />

      <!-- 10. CÓMO APLICAR? -->
      <ComoAplicar />

      <!-- 11. INSCRIPCIÓN Y TASAS -->
      <InscripcionTasas />

      <!-- 12. PAGOS -->
      <Pagos />

      <!-- 13. SOLICITUDES -->
      <Solicitudes />

    </div>
  </div>
</Layout>
