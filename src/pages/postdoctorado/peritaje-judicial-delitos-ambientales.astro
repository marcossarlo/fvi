---
import HeroPrograms from '~/components/widgets/HeroPrograms.astro';
import Content from '~/components/widgets/Content.astro';
import HeroSection from '~/components/widgets/HeroSection.astro';
import Steps from '~/components/widgets/Steps.astro';
import Layout from '~/layouts/PageLayout.astro';
import Features2 from '~/components/widgets/Features2.astro';
import FacultyMember from '~/components/widgets/FacultyMember.astro';
import { faculty } from '~/data/faculty';
import DatosEstadisticas from '~/components/postdoctorado/DatosEstadisticas.astro';
import Modalidades from '~/components/postdoctorado/Modalidades.astro';
import Estructura from '~/components/postdoctorado/Estructura.astro';
import ComoSeEstudia from '~/components/postdoctorado/ComoSeEstudia.astro';
import Becas from '~/components/postdoctorado/Becas.astro';
import ComoAplicar from '~/components/postdoctorado/ComoAplicar.astro';
import InscripcionTasas from '~/components/postdoctorado/InscripcionTasas.astro';
import Pagos from '~/components/postdoctorado/Pagos.astro';
import Solicitudes from '~/components/postdoctorado/Solicitudes.astro';
import ProgramTOC from '~/components/widgets/ProgramTOC.astro';

const metadata = {
  title: 'Posdoctorado en Peritaje Judicial en materia de delitos ambientales',
  description:
    'Especialízate con el Posdoctorado en Peritaje Judicial en Delitos Ambientales. Fórmate en pericia científica, valoración de daños y litigios ambientales en Iberoamérica.',
  keywords:
    'posdoctorado, peritaje judicial, delitos ambientales, pericia científica, valoración de daños ambientales, litigios ambientales, derecho ambiental, ciencias ambientales, Fondo Verde',
};

const tabs = [
  { label: '1. Presentación', id: 'presentacion' },
  { label: '2. El Postdoctorado', id: 'el-postdoctorado' },
  { label: '3. Modalidades', id: 'modalidades' },
  { label: '4. Estructura', id: 'estructura' },
  { label: '5. Asignaturas', id: 'asignaturas' },
  { label: '6. ¿Cómo se estudia?', id: 'como-se-estudia' },
  { label: '7. Claustro', id: 'claustro' },
  { label: '8. Certificación', id: 'certificacion' },
  { label: '9. Becas', id: 'becas' },
  { label: '10. ¿Cómo aplicar?', id: 'como-aplicar' },
  { label: '11. Inscripción', id: 'inscripcion' },
  { label: '12. Pagos', id: 'pagos' },
  { label: '13. Solicitudes', id: 'solicitudes' },
];
---

<Layout metadata={metadata} showSecondaryNav={false}>
  <!-- HeroPrograms ********************************************** -->
  <HeroPrograms
    tagline="Convocatoria Abierta 2026"
    subtitle="La valoración y cuantificación de los daños ambientales requiere la actuación técnica para una correcta evaluación científica."
    actions={[
      {
        variant: 'primary',
        text: 'Solicita información',
        href: '#solicitudes',
        icon: 'tabler:mail-forward',
        class: '!bg-primary !border-primary !text-white hover:!bg-secondary hover:!border-secondary transition-colors duration-300',
      },
      {
        variant: 'secondary',
        text: 'Ver Folleto Académico',
        href: 'https://drive.google.com/uc?export=download&id=1bX0xBLooTbdM9GZQ2amnofcBIB6qmVNl',
        icon: 'tabler:download',
        class: '!bg-transparent !text-white !border-[1px] !border-solid !border-white/50 hover:!bg-white/10 hover:!text-white hover:!border-white transition-all duration-300',
      },
    ]}
    image={{
      src: '~/assets/images/postdocs/fvi-postdoc-peritaje-judicial-delitos-ambientales.webp',
      alt: 'Postdoctorado en Peritaje Judicial en materia de delitos ambientales',
    }}
  >
    <Fragment slot="title">
      Posdoctorado en <br />
      <span class="text-primary dark:text-accent"> Peritaje Judicial en <br />materia de delitos ambientales</span>
    </Fragment>
  </HeroPrograms>

  <!-- DatosEstadisticas -->
  <DatosEstadisticas />  

  <div class="relative max-w-[100vw] overflow-x-hidden">
    <!-- Desktop Sidebar & Mobile Floating Pill -->
    <ProgramTOC tabs={tabs} />
    
    <!-- Main Content Wrapper that creates space for the Desktop Sidebar -->
    <div class="lg:ml-64 2xl:ml-[18rem] pb-24 lg:pb-0 transition-all duration-300">

      <!-- 1. PRESENTACIÓN *********************************** -->
      <Content
        id="presentacion"
        tagline="Presentación"
        title="Alberto Jiménez Madrid, PhD"
        subtitle="Director del Postdoctorado"
        items={[
          {
            title: 'Programa en extenso',
            icon: 'tabler:download',
            callToAction: {
              text: 'Descargar el Programa en Extenso',
              href: 'https://drive.google.com/uc?export=download&id=1bX0xBLooTbdM9GZQ2amnofcBIB6qmVNl',
              variant: 'primary',
            },
          },
        ]}
        image={{
          src: '~/assets/images/users/fvi-alberto-jimenez.webp',
          alt: 'Director del Postdoctorado - Alberto Jiménez Madrid, PhD',
        }}
      >
        <Fragment slot="content">
          <h3 class="text-xl font-semibold tracking-tight dark:text-white mb-2">
            La valoración y cuantificación de los daños ambientales requiere la actuación técnica para una <span class="text-primary">correcta evaluación científica</span>.
          </h3>
          <p class="pb-1">La evolución acelerada de la jurisprudencia internacional, junto con la modernización de la regulación ambiental y la creación de normas coherentes con la realidad, ha evidenciado la necesidad de contar con auxiliares de justicia capaces de mediar, conciliar, negociar o dirimir cuestiones que trascienden el ámbito jurídico y requieren conocimientos técnico‑científicos especializados. En este contexto, el Programa de <span class="text-primary font-semibold">Posdoctorado en</span> <span class="text-secondary font-semibold">Peritaje Judicial en materia de delitos ambientales</span> constituye una oportunidad para fortalecer el enfoque teórico, metodológico e instrumental de proyectos de investigación vinculados a la pericia científica, entendida como prueba esencial e irremplazable para determinar el éxito o fracaso de demandas y defensas en litigios ambientales.</p>
        </Fragment>

        <Fragment slot="bg">
          <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
        </Fragment>
      </Content>

      <!-- 2. EL POSTDOCTORADO ******************************* -->
      <Features2
        id="el-postdoctorado"
        tagline="El Postdoctorado"
        title="¿Por qué hacer el postdoctorado?"
        subtitle='La pericia científica constituye una prueba esencial e irremplazable en litigios ambientales, determinando el éxito o fracaso de demandas y defensas legales. El Programa de <span class="text-primary font-semibold">Posdoctorado en</span> <span class="text-secondary font-semibold">Peritaje Judicial en Delitos Ambientales</span> tiene como propósito fortalecer la actuación técnica mediante evaluaciones rigurosas y propuestas de solución que garanticen pruebas válidas y sostenibles en procesos judiciales. Dirigido a doctores de toda Iberoamérica y abierto a diversas disciplinas, el programa —<strong>con una duración de seis meses a un año</strong>— se desarrolla a través de un plan de actividades cuyo resultado esperado es la publicación de un artículo arbitrado por dos jurados, uno de ellos internacional, y la presentación de un informe que evidencie el cumplimiento de las tareas previstas.'
        columns={2}
        items={[
          {
            title: 'Objetivos del Programa',
            description:
              'El Programa de <span class="text-primary font-semibold">Posdoctorado en</span> <span class="text-secondary font-semibold">Peritaje Judicial en Delitos Ambientales</span>, se orientará de modo particular a: <ul class="list-disc ml-6 mt-2 space-y-1 text-muted"><li>Fortalecer el trabajo de investigadores que analicen los procesos e interacciones en el medio físico y sus sistemas interrelacionados que impactan en el medio ambiente, desde un paradigma interdisciplinario de ciencia crítica y fundamentalmente práctica que permitirán desarrollar con todas las garantías un informe pericial completo, todo con el fin de aportar en la actuación técnica para una correcta evaluación científica y elaboración de propuestas de solución, que conduzca a la obtención de una prueba pericial válida y sostenible para aquellos casos que lleguen a la vía judicial.</li><li>Contribuir al fortalecimiento teórico, metodológico e instrumental de proyectos de investigación vinculados a la Pericia Científica como prueba fundamental e irremplazable para determinar el éxito o fracaso de una demanda o de una defensa legal en un reclamo ambiental.</li></ul>',
            icon: 'tabler:circle-plus',
          },
          {
            title: 'Perfil del destinatario',
            description:
              'El programa está dirigido a: <ul class="list-disc ml-6 mt-2 space-y-1 text-muted"><li>Doctores de universidades extranjeras y nacionales del ámbito Jurídico-Social, Tecnológico, Sanitario y/o Científico, que persigan desarrollar un proyecto de investigación novedoso en el campo del peritaje judicial en materia de delitos ambientales.</li><li>Doctores de toda Iberoamérica y de cualquier disciplina, que posean especial interés sobre la praxis del dictamen pericial, los diagnósticos y pericias ambientales y que busquen desarrollar un proyecto de investigación en relación a dichos temas o se desempeñen laboralmente en áreas vinculadas.</li><li>Doctores en ingeniería, arquitectura, ciencias y demás profesionales con formación técnica, ambiental o jurídica que deseen adquirir la formación necesaria para manejar las tareas periciales, y estar capacitados para dar respuesta a esta nueva necesidad del mercado laboral.</li><li>Profesionales nacionales e internacionales con título doctoral en ciencias ambientales y/o jurídicas: abogados, químicos, geólogos, geógrafos, forestales, biólogos, ecólogos, bioquímicos, sanitarios, economistas, sociólogos, médicos, ingenieros, y demás disciplinas relacionadas con el entorno y la sociedad.</li><li>Doctorados en derecho, jueces, fiscales y auxiliares en administración de justicia que desean adquirir conocimientos sobre pericia ambiental y/o van a liderar proyectos que involucren: investigación, planeación y evaluación ambiental.</li></ul>',
            icon: 'tabler:users',
          },
        ]}
      />

      <!-- 3. MODALIDADES -->
      <Modalidades />

      <!-- 4. ESTRUCTURA -->
      <Estructura />

      <!-- 5. ASIGNATURAS ************************************ -->
      <HeroSection
        id="asignaturas"
        tagline="Asignaturas"
        title="Asignaturas de la Programación"
        image={{
          src: '~/assets/images/postdocs/fvi-postdoc-PJDA-Asignaturas.webp',
          alt: 'Asignaturas del programa de Posdoctorado en Peritaje Judicial en materia de delitos ambientales',
        }}
      >
        <Fragment slot="bg">
          <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
        </Fragment>
        <Fragment slot="subtitle">
          Son asignaturas obligatorias propuestas en la programación vigente, y a la vez es vinculante con el <span class="text-primary font-semibold">Trabajo Final de Investigación</span> - <span class="text-primary font-semibold">TFI</span>, por cuanto el postDoc deberá escoger una de las asignaturas de la programación y
          desarrollar algún aspecto que le resulte de interés.
        </Fragment>
      </HeroSection>

      <!-- 6. CÓMO SE ESTUDIA? -->
      <ComoSeEstudia />

      <!-- 7. CALUSTRO *************************************** -->
      <Content
        id="claustro"
        tagline="Claustro"
        title="Claustro Académico"
        items={[
          {
            title: 'Staff académico especializado',
            description:
              'El programa cuenta con un equipo de alto nivel, conformado por docentes universitarios e investigadores expertos en cada materia de conocimiento.',
            icon: 'tabler:users-group',
          },
          {
            title: 'Profesionales en activo',
            description:
              'Participan especialistas provenientes de la administración pública y de la empresa privada, aportando experiencia práctica en la gestión de proyectos.',
            icon: 'tabler:briefcase',
          },
          {
            title: 'Colaboración institucional',
            description:
              'Se suman profesionales de primer nivel de empresas, organismos oficiales e instituciones, directamente implicados en las áreas de conocimiento que abarca el posdoctorado.',
            icon: 'tabler:building',
          },
        ]}
        image={{
          src: '~/assets/images/fvi-claustro-academico.webp',
          alt: 'Claustro académico de Fondo Verde',
        }}
      >
        <Fragment slot="bg">
          <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
        </Fragment>
      </Content>
      <!-- Miembros del claustro -->
      {
        ['alberto-jimenez', 'maria-teresa-perez', 'angel-guillemes', 'loraine-giraud', 'erick-brenes'].map((id) => (
          <FacultyMember {...faculty[id]}>
            <Fragment slot="bg">
              <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark" />
            </Fragment>
          </FacultyMember>
        ))
      }

      <!-- 8. CERTIFICACIÓN ********************************** -->
      <Steps
        id="certificacion"
        tagline="Certificación"
        title="Evaluación y certificación"
        subtitle="Una vez cumplido y evaluado el Informe del Plan de Actividades y superado el Trabajo Final de Investigación, se expedirá un <strong>Diploma que acredite haber cursado el Programa de Postdoctorado</strong>."
        items={[
          {
            title: 'Diploma Oficial <br> <span class="font-normal">y Reconocimiento Institucional</span>',
            description: `El Diploma de Postdoctorado es expedido por <strong>Fondo Verde</strong>, inscrito en el Registro de Entidades Colaboradoras de la Junta de Castilla y León (España), en materia de Formación Profesional Ocupacional, con número <strong>11001</strong>.`,
            icon: 'tabler:certificate',
          },
          {
            title: 'Apostillado <br> <span class="font-normal">y Validez Internacional del Diploma</span>',
            description:
              'Desde España se realiza el proceso de apostillado por la Haya y la legitimación de firmas para que no tenga problemas a la hora de presentar el Diploma en un país fuera de España.',
            icon: 'tabler:certificate',
          },
        ]}
        classes={{ container: 'max-w-4xl' }}
      />
      <Features2
        columns={2}
        items={[
          {
            title: 'Requisitos para la Certificación PMPA™',
            description:
              'Los participantes que pretendan obtener la licencia <span class="font-bold text-primary">PMA™ Perito Ambiental Certificado y/o PMA™ Perito Forestal Certificado</span>, tienen que acreditar los requisitos de certificación relacionados con la credencial seleccionada, así como abonar las tasas y/o aranceles correspondientes.',
            icon: 'tabler:certificate-2',
          },
          {
            title: 'Licencia como Instructor PMPA™',
            description:
              'Los solicitantes que no cumplen los requisitos de experiencia pueden ser elegibles para una licencia <span class="font-bold text-primary">PMA™ Asistente de Perito Autorizado</span>.',
            icon: 'tabler:certificate-2',
          },
        ]}
        classes={{ container: 'max-w-4xl' }}
      />

      <!-- 9. BECAS -->
      <Becas />

      <!-- 10. CÓMO APLICAR? -->
      <ComoAplicar />

      <!-- 11. INSCRIPCIÓN Y TASAS -->
      <InscripcionTasas />

      <!-- 12. PAGOS -->
      <Pagos />

      <!-- 13. SOLICITUDES -->
      <Solicitudes />

    </div>
  </div>
</Layout>
