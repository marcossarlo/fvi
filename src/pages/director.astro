---
import Hero from '~/components/widgets/Hero.astro';
import Content from '~/components/widgets/Content.astro';
import Steps from '~/components/widgets/Steps.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Nuestro Director,  Juan Gamarra',
  description:
    'Juan Gamarra, Director General de Fondo Verde Institute. Más de 20 años de experiencia en gestión de proyectos de cooperación internacional y administración de instituciones del sector educacional ambiental.',
  keywords:
    'Juan Gamarra, Director Fondo Verde Institute, cooperación internacional, educación ambiental, gestión proyectos ambientales',
};
---

<Layout metadata={metadata}>
    <!-- Hero Widget ******************* -->
    <Hero
    tagline="El Instituto"
    >
    <Fragment slot="title">
        Nuestro
        <span class="text-primary dark:text-accent"> Director</span>
    </Fragment>

    <Fragment slot="subtitle">
        Conoce a <span class="font-semibold text-primary">Juan Gamarra</span>, Director General de
        <span class="font-semibold text-primary">Fondo Verde</span>{' '}
        <span class="font-semibold text-secondary">Institute</span>, con una reconocida trayectoria
        en la gestión de proyectos de cooperación internacional y la formación ambiental a nivel global.
    </Fragment>
    </Hero>

    <!-- Juan Gamarra en síntesis ******************* -->
    <Content
        tagline="Juan Gamarra"
        title="En síntesis"
        columns={3}
        items={[
        {
            icon: 'tabler:brand-linkedin',
            callToAction: {
            target: '_blank',
            text: 'LinkedIn',
            href: 'https://www.linkedin.com/in/juangamarraramos/',
            },
        },
        ]}
        image={{
            src: '~/assets/images/fvi-juan-gamarra_director.webp',
            alt: 'Juan Gamarra — Director General de Fondo Verde Institute',
        }}
    >
        <Fragment slot="content">
        <!-- <h2 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">En síntesis</h2> -->
        <p class="mb-2">
           Reconocida trayectoria profesional fundamentada en:
        </p>
        <p class="mb-2">
            18 años de experiencia para gestionar proyectos de cooperación internacional al desarrollo.
        </p>
        <p class="mb-2">
            15 años de experiencia en la administración de empresas del sector educacional.
        </p>
        <p class="mb-2">
            Además, ha participado como consultor y asesor técnico en el desarrollo de proyectos educativos basados en nuevas tecnologías, a nivel nacional y en el exterior. Amplia experiencia en trabajos de educación ambiental con preparación de materiales y dictado de cursos en varios países.
        </p>

        </Fragment>

        <Fragment slot="bg">
            <div class="absolute inset-0 bg-blue-50 dark:bg-transparent"></div>
        </Fragment>
    </Content>

    <!-- Trayectoria a través de los años ******************* -->
    <Steps
        title="Juan Gamarra a través de los años"
        tagline="Trayectoria"
        items={[
            {
            title: '1996 – 2001',
            description:
                'Grado en <strong>Ingeniería Forestal y Ambiental</strong>, Universidad Nacional del Centro (Perú).',
            icon: 'tabler:school',
            },
            {
            title: '2003 – Actualidad',
            description:
                '<strong>C.E.O y Fundador de Fondo Verde ONGDI</strong>, organización internacional dedicada a la conservación del medio ambiente y la formación ambiental.',
            icon: 'tabler:leaf',
            },
            {
            title: '2003',
            description:
                '<strong>Educador Ambiental</strong>, Educambiente (Chile).',
            icon: 'tabler:plant',
            },
            {
            title: '2003 – 2004',
            description:
                '<strong>Master en Educación Ambiental</strong>, Instituto de Investigaciones Ecológicas (España).',
            icon: 'tabler:certificate',
            },
            {
            title: '2004 – 2006',
            description:
                '<strong>Maestría en Estudios Regionales del Medio Ambiente y Desarrollo</strong>, Universidad Iberoamericana de Puebla (México).',
            icon: 'tabler:certificate',
            },
            {
            title: '2007 – 2009',
            description:
                'Estudios de <strong>Doctorado en Desarrollo Humano Sostenible</strong>, Universidad Bolivariana (Chile).',
            icon: 'tabler:certificate',
            },
            {
            title: '2008 – Actualidad',
            description:
                'Miembro del <strong>Comité Ad-hoc del Programa de Becas de Desarrollo Profesional</strong> de la Organización de Estados Americanos (OEA).',
            icon: 'tabler:globe',
            },
            {
            title: '2009 – 2010',
            description:
                'Integrante del <strong>Comité de Selección de Becarios del Programa Internacional de Becas de la Fundación Ford (IFP)</strong> para la Región Andina y Cono Sur (Perú).',
            icon: 'tabler:users',
            },
            {
            title: '2011 – Actualidad',
            description:
                '<strong>C.E.O del Instituto Internacional de Formación Ambiental</strong> (España).',
            icon: 'tabler:building',
            },
            {
            title: '2015 – 2017',
            description:
                '<strong>Co-Director de Másters</strong> en convenio entre la Universidad de Salamanca (España) y Fondo Verde.',
            icon: 'tabler:school',
            },
            {
            title: '2015 – 2017',
            description:
                'Estudios de <strong>Doctorado en Proyectos</strong>, Universidad Centro Panamericano de Estudios Superiores (México).',
            icon: 'tabler:certificate',
            },
            {
            title: '2015 – Actualidad',
            description:
                '<strong>C.E.O del Instituto Tecnológico del Medio Ambiente</strong> (Perú).',
            icon: 'tabler:building',
            },
            {
            title: '2015 – Actualidad',
            description:
                '<strong>C.E.O del Primer Programa Latinoamericano de Certificación Profesional en Medio Ambiente</strong> — PMA.',
            icon: 'tabler:award',
            },
            {
            title: '2018 – Actualidad',
            description:
                '<strong>Director General de Fondo Verde Institute</strong>, liderando la oferta académica internacional en formación ambiental de posgrado.',
            icon: 'tabler:star',
            },
            {
            title: '2020 – Actualidad',
            description:
                '<strong>Co-Responsable del Máster en Derecho Ambiental</strong>, Universidad de Alcalá (España) en convenio con Fondo Verde.',
            icon: 'tabler:scale',
            },
        ]}
    />

</Layout>
