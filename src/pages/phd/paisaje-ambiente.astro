---
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import HeroPrograms from '~/components/widgets/HeroPrograms.astro';
import Layout from '~/layouts/PageLayout.astro';
import StatsData from '~/components/phd/StatsData.astro';
import ProgramTOC from '~/components/widgets/ProgramTOC.astro';
import Features from '~/components/widgets/Features.astro';
import HeroSection from '~/components/widgets/HeroSection.astro';
import ProgramCurriculum from '~/components/phd/ProgramCurriculum.astro';
import ResearchCurriculum from '~/components/phd/ResearchCurriculum.astro';
import ProgramMethodology from '~/components/phd/ProgramMethodology.astro';
import PhdProject from '~/components/phd/PhdProject.astro';
import { paisajeAmbienteCurriculum, paisajeAmbienteResearch } from '~/data/phd/paisaje-ambiente';
import FacultyMember from '~/components/widgets/FacultyMember.astro';
import { faculty } from '~/data/faculty';
import Image from '~/components/common/Image.astro';
import Scholarship from '~/components/phd/Scholarship.astro';
import Admission from '~/components/phd/Admission.astro';
import Payments from '~/components/phd/Payments.astro';
import PaymentMethods from '~/components/phd/PaymentMethods.astro';
import Requests from '~/components/phd/Requests.astro';

const metadata = {
    title: 'Doctorado en Paisaje y Ambiente',
    description:
        'Fórmate con el Doctorado en Paisaje y Ambiente online. Especialízate en el análisis, ordenación y gestión del paisaje, ecología urbana y desarrollo territorial.',
    keywords:
        'doctorado en paisaje y ambiente, ordenación del paisaje, rvoe méxico, ecología del paisaje, gestión del territorio, fondo verde, patrimonio cultural, educación online',
};

const tabs = [
    { id: 'presentacion', label: '1. Presentación' },
    { id: 'el-doctorado', label: '2. El Doctorado' },
    { id: 'investigacion', label: '3. Investigación' },
    { id: 'asignaturas', label: '4. Asignaturas' },
    { id: 'proyecto', label: '5. Proyecto' },
    { id: 'metodologia', label: '6. Metodología' },
    { id: 'profesorado', label: '7. Profesorado' },
    { id: 'beneficios', label: '8. Beneficios' },
    { id: 'campos-de-accion', label: '9. Campos de Acción' },
    { id: 'titulacion', label: '10. Titulación' },
    { id: 'becas', label: '11. Becas' },
    { id: 'inscripcion', label: '12. Inscripción' },
    { id: 'pagos', label: '13. Pagos' },
    { id: 'medios-de-pago', label: '14. Medios de Pago' },
    { id: 'solicitudes', label: '15. Solicitudes' },
];
---

<Layout metadata={metadata} showSecondaryNav={false}>
    <!-- HeroPrograms ********************************************** -->
    <HeroPrograms
        tagline="Convocatoria Abierta 2026"
        subtitle="Soluciones sostenibles para la gestión, planeamiento y recuperación de los territorios"
        actions={[
            {
                variant: 'primary',
                text: 'Solicita información',
                href: '#solicitudes',
                icon: 'tabler:mail-forward',
                class: '!bg-primary !border-primary !text-white hover:!bg-secondary hover:!border-secondary transition-colors duration-300',
            },
            {
                variant: 'secondary',
                text: 'Ver Folleto Académico',
                href: 'https://drive.google.com/file/d/1OXo1Go_WGiDZFb8jW8IiZSZ5latwjZVQ/view',
                target: '_blank',
                icon: 'tabler:download',
                class: '!bg-transparent !text-white !border-[1px] !border-solid !border-white/50 hover:!bg-white/10 hover:!text-white hover:!border-white transition-all duration-300',
            },
        ]}
        image={{
        src: '~/assets/images/doctorados/fvi-phd-paisaje-ambiente.webp',
        alt: 'Imagen del Doctorado en Paisaje y Ambiente',
        }}
    >
        <Fragment slot="title">
            Doctorado en <br />
            <span class="text-secondary dark:text-accent"> Paisaje y Ambiente</span>
        </Fragment>
    </HeroPrograms>

    <!-- DatosEstadisticas -->
    <StatsData duration="36" /> 

    <div class="relative max-w-[100vw] overflow-x-hidden">
        <!-- Desktop Sidebar & Mobile Floating Pill -->
        <ProgramTOC tabs={tabs} />

        <!-- Main Content Wrapper that creates space for the Desktop Sidebar -->
        <div class="lg:ml-64 2xl:ml-[18rem] pb-24 lg:pb-0 transition-all duration-300">
            <!-- 1. PRESENTACIÓN *********************************** -->
            <Content
                id="presentacion"
                tagline="Presentación"
                title='Doctorado en <span class="text-primary">Paisaje y Ambiente</span>'
                subtitle="El espacio libre como elemento que estructura y contribuye a la mejora ambiental en la ciudad contemporánea y el territorio."
                items={[
                    {
                        title: 'Métodos y aproximaciones al estudio del paisaje',
                        description: 'Se centra en la valoración del paisaje como recurso para la conservación de áreas naturales, la planificación de usos del territorio y la restauración de zonas alteradas, respondiendo a problemas prácticos de gestión territorial.',
                        icon: 'tabler:map',
                    },
                    {
                        title: 'Formación avanzada en gestión del espacio libre',
                        description: 'Prepara a los estudiantes para resolver con rigor científico los problemas que inciden directamente en la planificación y gestión de paisajes, contribuyendo a la mejora ambiental en la ciudad contemporánea y en diversos contextos territoriales.',
                        icon: 'tabler:trees',
                    },
                    {
                        title: 'Enfoque interdisciplinario y transdisciplinario del paisaje',
                        description: 'Integra teorías, métodos y datos de múltiples disciplinas en narrativas coherentes sobre patrones y procesos del paisaje, abarcando diferentes escalas de análisis: regional, nacional e internacional.',
                        icon: 'tabler:route',
                    },
                ]}
                image={{
                src: '~/assets/images/doctorados/fvi-phd-paisaje-ambiente-portada.webp',
                alt: 'Imagen de presentación del Doctorado de Paisaje y Ambiente',
                }}
            >
                <Fragment slot="bg">
                    <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
                </Fragment>
            </Content>

            <!-- 2. EL DOCTORADO  ******************************* -->
            <Features2
                id="el-doctorado"
                tagline="El Doctorado"
                title="¿Por qué hacer el Doctorado?"
                subtitle='El <span class="text-primary font-semibold">Doctorado en</span> <span class="text-secondary font-semibold">Paisaje y Ambiente</span> forma investigadores de alto nivel capaces de abordar, con rigor científico, los problemas que afectan al espacio libre como elemento estructurador del entorno y su contribución a la mejora ambiental de la ciudad contemporánea. El programa desarrolla competencias para evaluar, planificar e intervenir en paisajes, aportando soluciones aplicadas a la gestión territorial, la conservación y la restauración, y fortaleciendo la capacidad técnica y conceptual necesaria para influir en procesos de planificación y políticas públicas relacionadas con el paisaje.'
                columns={2}
                items={[
                {
                    title: 'Objetivos del Doctorado',
                    description:
                    'Los objetivos específicos del programa son: <ul class="list-disc ml-6 mt-2 space-y-1 text-muted"><li>Generar conocimiento de frontera sobre los procesos de formación y de degradación, así como la forma de prevenir, corregir y curar las degradaciones paisajísticas, así como de crear nuevos paisajes.</li><li>Profundizar en el conocimiento de la creación de la noción de paisaje en América Latina, sus influencias externas y sus condicionantes internas, los instrumentos y principios internacionales de ordenación y protección del paisaje en su aplicación actual.</li><li>Estudiar los métodos de análisis, interpretación, valoración y protección del paisaje y el patrimonio.</li><li>Establecer claves de interpretación del patrimonio natural considerando aspectos del paradigma de la complejidad.</li><li>Formar investigadores con una sólida base científica en aspectos relacionados con el medio ambiente.</li></ul>',
                    icon: 'tabler:school',
                },
                {
                    title: 'Perfil del destinatario',
                    description:
                    'El Doctorado está dirigido a: <ul class="list-disc ml-6 mt-2 space-y-1 text-muted"><li><strong>Profesionales:</strong> Arquitectos, urbanistas, biólogos, ecólogos, agrónomos, forestales, geógrafos e ingenieros que aspiran a intervenir positivamente en el territorio.</li><li><strong>Académicos e Investigadores:</strong> Profesionales motivados por la valoración del paisaje y su relación con la gestión del territorio.</li><li><strong>Especialistas:</strong> Interesados en investigación científica, gestión de la naturaleza, patrimonio y planificación espacial.</li></ul>',
                    icon: 'tabler:users',
                },
                ]}
            />

            <!-- 3. INVESTIGACIÓN  ******************************* -->
            <Features
                id="investigacion"
                tagline="Investigación"
                title="Líneas de Investigación"
                subtitle="A continuación, se relacionan las líneas de investigación de las que consta el programa de doctorado en su período de investigación."
                items={[
                    {
                        title: 'Arquitectura del paisaje',
                        description: 'Diseño e integración de espacios abiertos, considerando la estética y la funcionalidad ecológica.',
                        icon: 'tabler:trees',
                    },
                    {
                        title: 'Urbanismo y ordenación del territorio',
                        description: 'Análisis, diagnóstico e intervención para la planificación de áreas urbanas y rurales sostenibles.',
                        icon: 'tabler:building-arch',
                    },
                    {
                        title: 'Gestión del patrimonio y el paisaje',
                        description: 'Puesta en valor y manejo de los recursos paisajísticos y culturales heredados.',
                        icon: 'tabler:building-castle',
                    },
                    {
                        title: 'Ecología evolutiva y conservación',
                        description: 'Estudio de los sistemas biológicos y creación de medidas para preservar la biodiversidad.',
                        icon: 'tabler:plant-2',
                    },
                    {
                        title: 'Paisajes culturales sostenibles',
                        description: 'Vinculación de patrimonio, proyectos territoriales y desarrollo local bajo modelos sustentables.',
                        icon: 'tabler:map',
                    },
                    {
                        title: 'Cartografía y SIG',
                        description: 'Uso de Teledetección y Sistemas de Información Geográfica para el mapeo territorial.',
                        icon: 'tabler:world-latitude',
                    },
                    {
                        title: 'Impacto ambiental sobre el paisaje',
                        description: 'Evaluación de las transformaciones y riesgos que afectan la calidad visual y ecológica del entorno.',
                        icon: 'tabler:alert-triangle',
                    },
                    {
                        title: 'Metodologías no invasivas',
                        description: 'Procedimientos técnicos aplicados al patrimonio y paisaje sin alterar su integridad física.',
                        icon: 'tabler:microscope',
                    },
                    {
                        title: 'Estudios del borde urbano',
                        description: 'Análisis morfológico de las zonas de transición entre la ciudad y el medio natural.',
                        icon: 'tabler:geometry',
                    },
                    {
                        title: 'Recreación y Simulación Ambiental',
                        description: 'Proyectos de recreación comunitaria respaldados por modelos de simulación ambiental avanzados.',
                        icon: 'tabler:device-laptop',
                    },
                ]}
            >
                <Fragment slot="bg">
                    <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
                </Fragment>
            </Features>

            <!-- 4. ASIGNATURAS  ******************************* -->
            <!-- Carga horaria -->
            <Features2
                id="asignaturas"
                tagline="Asignaturas"
                title="Estructura del programa"
                subtitle='El <span class="text-primary font-semibold">Doctorado en</span> <span class="text-secondary font-semibold">Paisaje y Ambiente</span>, es un programa multidisciplinario que tiene una duración de <strong>36 meses (3 años)</strong>, estructurados en un periodo de formación, un periodo de investigación, el <strong>Proyecto de Tesis doctoral</strong> y un artículo científico con un total de <strong>1,600 horas lectivas (100 créditos)</strong>.'
                columns={2}
                items={[
                {
                    title: 'Periodo de Formación',
                    description:
                    '<ul class="list-disc ml-6 mt-2 space-y-1 text-white"><li>El plan de estudios está compuesto de <strong>cuatro trimestres</strong> intensivos donde se dictan <strong>doce cursos teóricos</strong>.</li><li>Garantiza el correcto enfoque del participante a través del acompañamiento de un Tutor nombrado por la <strong>Comisión Académica</strong>.</li></ul>',
                    icon: 'tabler:book',
                    classes: { 
                        panel: 'text-white bg-teal-700 dark:bg-teal-500/30',
                        icon: 'text-green-500'
                    },
                },
                {
                    title: 'Periodo de Investigación',
                    description:
                    '<ul class="list-disc ml-6 mt-2 space-y-1 text-white"><li><strong>Componente de Investigación</strong>; seminarios prácticos de seguimiento riguroso.</li><li><strong>Tesis Doctoral</strong>; desarrollo y presentación sobre un área o experimentación paisajística y ecológica vinculante.</li><li><strong>Publicación de artículo científico</strong>.</li></ul>',
                    icon: 'tabler:microscope',
                    classes: { 
                        panel: 'text-white bg-teal-700 dark:bg-teal-500/30',
                        icon: 'text-green-500'
                    },
                },
                ]}
            />
            <!-- 4.1. Periodo de Formación -->
            <HeroSection
                tagline="Periodo de Formación"
                title="Carga Horaria y Asignaturas del Curso"
                subtitle='El plan de formación del <span class="text-primary font-semibold">Doctorado en</span> <span class="text-secondary font-semibold">Paisaje y Ambiente</span> propone un recorrido 360º por las materias fundamentales vinculadas al análisis, ordenación y gestión del paisaje, explorando las relaciones e implicaciones del paisaje con diversos aspectos como el medio urbano, el patrimonio cultural, el turismo y los espacios naturales protegidos. También se abordan temas de conservación de la naturaleza a nivel de paisaje, con énfasis en el uso inicial de Sistemas de Información Geográfica (SIG). Todos los cursos son impartidos por profesores con doctorado y experiencia en cada materia.'
            >
                <Fragment slot="content">
                    <p class="text-base text-left mb-6">El <strong>currículo del programa de doctorado</strong> se precisa a continuación:</p>
                    <ProgramCurriculum courses={paisajeAmbienteCurriculum.courses} />
                </Fragment>
            </HeroSection>            
            <!-- 4.2. Periodo de Investigación -->
            <HeroSection
                tagline="Periodo de Investigación"
                title="Carga Horaria y Asignaturas del Seminario"                
            >
                <Fragment slot="content">
                    <ResearchCurriculum {...paisajeAmbienteResearch} />
                </Fragment>
            </HeroSection>

            <!-- 5. PROYECTO DE TESIS DOCTORAL -->
            <PhdProject />

            <!-- 6. METODOLOGÍA DE ENSEÑANZA -->
            <ProgramMethodology />

            <!-- 7. PROFESORADO -->
            <Content
                id="profesorado"
                tagline="Profesorado"
                title="Profesorado y Tutoría"
                items={[
                    {
                        title: 'Composición del profesorado',
                        description:
                            'El profesorado está formado por personal universitario docente e investigador y por profesionales en activo en la administración pública y en la empresa privada, con residencia en varios países.',
                        icon: 'tabler:school',
                    },
                    {
                        title: 'Equipo central y habilidades complementarias',
                        description:
                            'Cuentan con un equipo central en Perú y habilidades complementarias que incluyen dominio de varios idiomas, experiencia con una amplia gama de culturas y la capacidad de trabajar de manera eficiente desde oficinas virtuales.',
                        icon: 'tabler:world-latitude',
                    },
                    {
                        title: 'Participación de profesionales externos',
                        description:
                            'Participan profesionales de primer nivel de otras empresas, organismos oficiales e instituciones, todos ellos directamente implicados en las diferentes áreas de conocimiento del programa.',
                        icon: 'tabler:users-group',
                    },
                ]}
                image={{
                    src: '~/assets/images/fvi-profesorado-tutoria.webp',
                    alt: 'Imagen del profesorado del Doctorado de Fondo Verde',
                }}
                >
                <Fragment slot="bg">
                    <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
                </Fragment>
            </Content>
            {
                ['gonzalo-fuente', 'diana-duran', 'alberto-jimenez', 'loraine-giraud', 'maria-teresa-perez', 'susan-smith'].map((id) => {
                    const prof = faculty[id];
                    if(!prof) return null;
                    return (
                    <FacultyMember {...prof}>
                        <Fragment slot="bg">
                        <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark" />
                        </Fragment>
                    </FacultyMember>
                    )
                })
            }

            <!-- 8. BENEFICIOS -->
            <Features
                id="beneficios"
                tagline="Beneficios"
                title="Beneficios anticipados e impacto profesional"
                subtitle='Las características fundamentales del egresado del programa de <span class="text-primary font-semibold">Doctorado en</span> <span class="text-secondary font-semibold">Paisaje y Ambiente</span>, son:'
                items={[
                    {
                        title: 'Investigación de impacto',
                        description: 'Desarrollar investigaciones en las áreas de patrimonio cultural y natural, paisajes culturales y conservación para incidir positivamente en localidades urbanas y rurales.',
                        icon: 'tabler:microscope',
                    },
                    {
                        title: 'Análisis y caracterización',
                        description: 'Aplicar herramientas y metodologías avanzadas para el estudio detallado y la caracterización técnica del paisaje.',
                        icon: 'tabler:chart-line',
                    },
                    {
                        title: 'Gestión Sostenible',
                        description: 'Identificar elementos relevantes en el territorio y el paisaje imprescindibles para comprender y gestionar nuestro mundo de forma sostenible.',
                        icon: 'tabler:leaf',
                    },
                    {
                        title: 'Diagnóstico y Prospectiva',
                        description: 'Analizar información crítica sobre el paisaje, patrimonio y ciudad para realizar diagnósticos precisos y estudios de escenarios futuros.',
                        icon: 'tabler:search',
                    },
                    {
                        title: 'Validación Multidisciplinar',
                        description: 'Validar proyectos e intervenciones analizando sus consecuencias desde una perspectiva multidisciplinar e integradora.',
                        icon: 'tabler:checkup-list',
                    },
                ]}
            />    
            
            <!-- 9. CAMPOS DE ACCIÓN -->
            <Features
                id="campos-de-accion"
                tagline="Campos de Acción"
                title="Campos de Acción Profesionales"
                subtitle="Líder en ordenación de proyectos e investigación de primer impacto frente a entornos ecológicos y artificiales."
                items={[
                    {
                        title: 'Asesoría Científica',
                        description: 'Asesor en proyectos de protección y gestión del paisaje, integrando y liderando equipos pluridisciplinares.',
                        icon: 'tabler:microscope',
                    },
                    {
                        title: 'Investigación del Patrimonio',
                        description: 'Desarrollo de investigaciones para la puesta en valor y difusión del patrimonio natural y cultural.',
                        icon: 'tabler:building-castle',
                    },
                    {
                        title: 'Colaboración Académica',
                        description: 'Investigador activo en su área de conocimiento, participando en redes de colaboración académica y científica internacional.',
                        icon: 'tabler:network',
                    },
                    {
                        title: 'Consultoría Especializada',
                        description: 'Consultor en despachos de arquitectura, urbanismo, ingeniería, infraestructuras y paisajismo.',
                        icon: 'tabler:briefcase',
                    },
                    {
                        title: 'Políticas Públicas',
                        description: 'Diseño e ejecución de políticas públicas y proyectos de desarrollo en gestión cultural, patrimonial y turística.',
                        icon: 'tabler:building-community',
                    },
                    {
                        title: 'Gestión Ambiental y Paisajística',
                        description: 'Gestor en análisis, diagnosis y propuestas territoriales y ambientales de alto impacto.',
                        icon: 'tabler:leaf',
                    },
                    {
                        title: 'Análisis Técnico Administrativo',
                        description: 'Analista y gestor en áreas técnicas de la administración pública para políticas de intervención en el territorio.',
                        icon: 'tabler:map-search',
                    },
                ]}
            >
                <Fragment slot="bg">
                    <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
                </Fragment>
            </Features> 

            <!-- 10. TITULACIÓN -->            
            <Content
                id='titulacion'
                title='Título Oficial'
                tagline="Titulación"
                isReversed
                image={{
                    src: '~/assets/images/fvi-titulacion.webp',
                    alt: 'Imagen de titulación del Doctorado de Fondo Verde',
                }}
             >
                <Fragment slot="content">                    
                    <p class="text-xl text-muted mb-2 dark:text-slate-300">
                        La <strong>Universidad Centro Panamericano de Estudios Superiores</strong> - <strong>UNICEPES</strong>, otorga el Grado de <span class="text-primary font-semibold">Doctor (a) en Paisaje y Ambiente</span> con <strong>Reconocimiento de Validez Oficial de Estudios</strong> (<strong>RVOE</strong>) otorgado por la Secretaría de Educación del Gobierno del Estado de Michoacán (<span class="text-secondary font-semibold">RVOE No. DOC201209</span> | <span class="text-primary font-semibold">Clave D.G.P. Dirección General de Profesiones N° 620604</span>) y con Reconocimiento en todos los países en los que México haya suscrito convenio a través del Convenio de la Haya (1961).
                    </p>      
                    <div class="flex justify-center">
                        <div class="max-w-xs md:max-w-[400px]">
                            <Image 
                                src="~/assets/images/fvi-rvoe-logo.webp" 
                                alt="Logo RVOE" 
                                width={400}
                                class="h-auto dark:brightness-110"
                            />
                        </div>
                    </div>
                </Fragment>
            </Content>

            <!-- 11. BECAS -->
            <Scholarship />

            <!-- 12. INSCRIPCIÓN -->
            <Admission />

            <!-- 13. PAGOS -->
            <Payments />

            <!-- 14. MEDIOS DE PAGO -->
            <PaymentMethods />

            <!-- 15. SOLICITUDES -->
            <Requests />

        </div>
        <!-- END Main Content -->

    </div>
    <!-- END Desktop Sidebar & Mobile Floating Pill -->

</Layout>
