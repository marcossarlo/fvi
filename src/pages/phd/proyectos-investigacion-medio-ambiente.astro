---
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import HeroPrograms from '~/components/widgets/HeroPrograms.astro';
import Layout from '~/layouts/PageLayout.astro';
import StatsData from '~/components/phd/StatsData.astro';
import ProgramTOC from '~/components/widgets/ProgramTOC.astro';
import Features from '~/components/widgets/Features.astro';
import HeroSection from '~/components/widgets/HeroSection.astro';
import ProgramCurriculum from '~/components/phd/ProgramCurriculum.astro';
import ResearchCurriculum from '~/components/phd/ResearchCurriculum.astro';
import ProgramMethodology from '~/components/phd/ProgramMethodology.astro';
import PhdProject from '~/components/phd/PhdProject.astro';
import { proyectosInvestigacionCurriculum, proyectosInvestigacionResearch } from '~/data/phd/proyectos-investigacion-medio-ambiente';
import FacultyMember from '~/components/widgets/FacultyMember.astro';
import { faculty } from '~/data/faculty';
import Image from '~/components/common/Image.astro';
import Scholarship from '~/components/phd/Scholarship.astro';
import Admission from '~/components/phd/Admission.astro';
import Payments from '~/components/phd/Payments.astro';
import PaymentMethods from '~/components/phd/PaymentMethods.astro';
import Requests from '~/components/phd/Requests.astro';

const metadata = {
    title: 'Doctorado en Proyectos: Línea de Investigación en Medio Ambiente',
    description:
        'Formación doctoral de alto nivel en gestión ambiental y sostenibilidad. Investiga modelos de planificación, cambio climático y dirección de proyectos sostenibles.',
    keywords:
        'doctorado en proyectos ambientales, gestión ambiental, desarrollo sostenible, investigación en medio ambiente, sostenibilidad, proyectos sostenibles, doctorado medio ambiente',
};

const tabs = [
    { id: 'presentacion', label: '1. Presentación' },
    { id: 'el-doctorado', label: '2. El Doctorado' },
    { id: 'investigacion', label: '3. Investigación' },
    { id: 'asignaturas', label: '4. Asignaturas' },
    { id: 'proyecto', label: '5. Proyecto' },
    { id: 'metodologia', label: '6. Metodología' },
    { id: 'profesorado', label: '7. Profesorado' },
    { id: 'beneficios', label: '8. Beneficios' },
    { id: 'campos-de-accion', label: '9. Campos de Acción' },
    { id: 'titulacion', label: '10. Titulación' },
    { id: 'becas', label: '11. Becas' },
    { id: 'inscripcion', label: '12. Inscripción' },
    { id: 'pagos', label: '13. Pagos' },
    { id: 'medios-de-pago', label: '14. Medios de Pago' },
    { id: 'solicitudes', label: '15. Solicitudes' },
];
---

<Layout metadata={metadata} showSecondaryNav={false}>
    <!-- HeroPrograms ********************************************** -->
    <HeroPrograms
        tagline="Convocatoria Abierta 2026"
        subtitle="Investigación avanzada en gestión de proyectos ambientales"
        actions={[
            {
                variant: 'primary',
                text: 'Solicita información',
                href: '#solicitudes',
                icon: 'tabler:mail-forward',
                class: '!bg-primary !border-primary !text-white hover:!bg-secondary hover:!border-secondary transition-colors duration-300',
            },
            {
                variant: 'secondary',
                text: 'Ver Folleto Académico',
                href: 'https://drive.google.com/file/d/1O7Catswtga26i6NbbVi0MPOCYDhlH_wy/view',
                target: '_blank',
                icon: 'tabler:download',
                class: '!bg-transparent !text-white !border-[1px] !border-solid !border-white/50 hover:!bg-white/10 hover:!text-white hover:!border-white transition-all duration-300',
            },

        ]}
        image={{
        src: '~/assets/images/doctorados/fvi-phd-proyectos-investigacion-medio-ambiente.webp',
        alt: 'Imagen del Doctorado en Proyectos Medio Ambientales',
        }}
    >
        <Fragment slot="title">
            Doctorado en <br />
            <span class="text-secondary dark:text-accent"> Proyectos: Línea de Investigación en Medio Ambiente</span>
        </Fragment>
    </HeroPrograms>

    <!-- DatosEstadisticas -->
    <StatsData /> 

    <div class="relative max-w-[100vw] overflow-x-hidden">
        <!-- Desktop Sidebar & Mobile Floating Pill -->
        <ProgramTOC tabs={tabs} />

        <!-- Main Content Wrapper that creates space for the Desktop Sidebar -->
        <div class="lg:ml-64 2xl:ml-[18rem] pb-24 lg:pb-0 transition-all duration-300">
            <!-- 1. PRESENTACIÓN *********************************** -->
            <Content
                id="presentacion"
                tagline="Presentación"
                title='Doctorado en Proyectos: <span class="text-primary">Línea de Investigación en Medio Ambiente</span>'
                subtitle="Formación avanzada para diseñar y gestionar proyectos sostenibles con impacto local, regional y global."
                items={[
                    {
                        title: 'Gestión de proyectos ambientales',
                        description: 'Implica un conjunto complejo de acciones y medidas orientadas al diseño de un futuro sustentable, considerando los distintos contextos sociohistóricos y geográficos, y enfrentando retos propios de la gestión ambiental.',
                        icon: 'tabler:briefcase',
                    },
                    {
                        title: 'Particularidades de la gestión ambiental',
                        description: 'A diferencia de otros sectores, los estándares ambientales son recientes y la cultura de gestión aún enfrenta debates y dudas, lo que exige una mayor profundización en técnicas de contextualización, implementación y aseguramiento de logros.',
                        icon: 'tabler:settings-automation',
                    },
                    {
                        title: 'Formación de investigadores en sostenibilidad',
                        description: 'El programa busca preparar profesionales de alto nivel capaces de generar conocimientos innovadores en planeación, formulación y gestión de proyectos sostenibles, tanto en ambientes urbanos como rurales, y en diferentes escalas de intervención.',
                        icon: 'tabler:microscope',
                    },
                ]}
                image={{
                src: '~/assets/images/doctorados/fvi-phd-proyectos-investigacion-medio-ambiente-portada.webp',
                alt: 'Imagen de presentación del Doctorado de Proyectos',
                }}
            >
                <Fragment slot="bg">
                    <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
                </Fragment>
            </Content>

            <!-- 2. EL DOCTORADO  ******************************* -->
            <Features2
                id="el-doctorado"
                tagline="El Doctorado"
                title="¿Por qué hacer el Doctorado?"
                subtitle='El <span class="text-primary font-semibold">Doctorado en Proyectos:</span> <span class="text-secondary font-semibold"> Línea de Investigación en Medio Ambiente</span> forma investigadores de alto nivel capaces de generar conocimientos innovadores en la planeación, formulación y gestión de proyectos sostenibles, aplicables tanto al ambiente urbano como rural y en micro y macro escala. El programa amplía el saber de profesionales interesados en temas prioritarios del desarrollo sostenible y en la gestión de proyectos ambientales, con especial pertinencia para contextos de países en vías de desarrollo, donde se requieren enfoques adaptados a realidades socioambientales específicas.'
                columns={2}
                items={[
                {
                    title: 'Objetivos del Doctorado',
                    description:
                    'Los objetivos específicos del programa son: <ul class="list-disc ml-6 mt-2 space-y-1 text-muted"><li>Estudiar la relación entre sociedad y territorio, basados en un análisis de sus componentes biofísicos, socioeconómicos, culturales y políticos con el fin de poder entregar propuestas y soluciones que se adapten a las especificidades locales y regionales.</li><li>Proporcionar herramientas teóricas, metodológicas e instrumentales para elaborar, implementar, sistematizar y evaluar proyectos sustentables, así como la gestión de este proceso.</li><li>Formar proyectistas idóneos en la nueva cultura ambiental, competentes para gerenciar los procesos de cambio y diseñar las estrategias futuras, con base en una visión sistémica de la sustentabilidad y el desarrollo humano.</li><li>Identificar un problema que se pretende solucionar a través de una acción de desarrollo, para distinguir y aplicar conceptos básicos de planificación de proyectos y finalmente establecer un sistema de monitoreo para verificar el rumbo del mismo.</li></ul>',
                    icon: 'tabler:circle-plus',
                },
                {
                    title: 'Perfil del destinatario',
                    description:
                    'El Doctorado está dirigido a: <ul class="list-disc ml-6 mt-2 space-y-1 text-muted"><li>Todo profesional con perspectiva interdisciplinaria de lo ambiental, que acredite competencias y experiencia en el campo relacionado con la gestión ambiental y el desarrollo y que requieran participar como auspiciadores, generadores, directores, planificadores, ejecutores o supervisores de proyectos sostenibles.</li><li>Titulados universitarios de las distintas disciplinas (Ciencias Ambientales, Ciencias Económico Administrativas, Ingeniería, Arquitectura, Abogados, Geógrafos y similares) interesados en el área de la sustentabilidad ambiental.</li><li>Docentes, proyectistas y funcionarios del sector público y privado con desempeño profesional en desarrollo urbano y la sustentabilidad o en equipos de proyectos.</li></ul>',
                    icon: 'tabler:users',
                },
                ]}
            />

            <!-- 3. INVESTIGACIÓN  ******************************* -->
            <Features
                id="investigacion"
                tagline="Investigación"
                title="Líneas de Investigación"
                subtitle="A continuación se relacionan las líneas de investigación de las que consta el programa de doctorado en su período de investigación."
                items={[
                    {
                        title: 'Modelos de planificación y gestión de proyectos y programas de desarrollo sostenible',
                        description: 'Estudio y aplicación de modelos avanzados para la estructuración de programas que promuevan la sostenibilidad a largo plazo en diversos contextos.',
                        icon: 'tabler:layout-grid',
                    },
                    {
                        title: 'Dirección y gestión de proyectos ambientales',
                        description: 'Liderazgo técnico y administrativo en la ejecución de iniciativas orientadas a la protección y mejora del entorno natural.',
                        icon: 'tabler:briefcase',
                    },
                    {
                        title: 'Diseño de metodologías, enfoques y herramientas participativas de evaluación',
                        description: 'Creación de instrumentos evaluativos que integren la participación social para medir el impacto y éxito de los proyectos ambientales.',
                        icon: 'tabler:users-group',
                    },
                    {
                        title: 'Tecnologías y métodos para la gestión sostenible',
                        description: 'Implementación de soluciones tecnológicas y metodológicas modernas para optimizar el uso de recursos y minimizar impactos negativos.',
                        icon: 'tabler:device-laptop',
                    },
                    {
                        title: 'Desarrollo y aplicación de metodologías para el desarrollo de sistemas de toma de decisiones',
                        description: 'Sistemas rigurosos basados en datos para fundamentar decisiones estratégicas en la planeación y gestión territorial.',
                        icon: 'tabler:chart-arrows-vertical',
                    },
                    {
                        title: 'Cambio Climático',
                        description: 'Investigación sobre medidas de mitigación y adaptación ante los desafíos globales del calentamiento planetario.',
                        icon: 'tabler:temperature-plus',
                    },
                    {
                        title: 'Economía del Medio Ambiente y Desarrollo',
                        description: 'Análisis de la viabilidad económica y financiera de proyectos bajo criterios de responsabilidad ambiental y social.',
                        icon: 'tabler:coin',
                    },
                    {
                        title: 'Gestión Sostenible de los Recursos Naturales y Ambientales',
                        description: 'Estrategias para la explotación equilibrada y el mantenimiento de los servicios ecosistémicos esenciales.',
                        icon: 'tabler:seeding',
                    },
                    {
                        title: 'Conservación y Restauración de Ecosistemas',
                        description: 'Proyectos enfocados en la recuperación de la biodiversidad y la regeneración de espacios degradados.',
                        icon: 'tabler:leaf',
                    },
                    {
                        title: 'Sostenibilidad Ambiental',
                        description: 'Visión integral de la sustentabilidad para garantizar que las acciones del presente no comprometan el futuro del planeta.',
                        icon: 'tabler:world',
                    },
                ]}
            >
                <Fragment slot="bg">
                    <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
                </Fragment>
            </Features>

            <!-- 4. ASIGNATURAS  ******************************* -->
            <!-- Carga horaria -->
            <Features2
                id="asignaturas"
                tagline="Asignaturas"
                title="Estructura del programa"
                subtitle='El <span class="text-primary font-semibold">Doctorado en Proyectos:</span> <span class="text-secondary font-semibold"> Línea de Investigación en Medio Ambiente</span>, es un programa multidisciplinario que tiene una duración de <strong>24 meses</strong> (<strong>8 trimestres</strong>), estructurados en un periodo de formación, un periodo de investigación, el <strong>Proyecto de Tesis Doctoral</strong> y un artículo científico con un total de <strong>1,200 horas lectivas</strong> (<strong>75 créditos</strong>).'
                columns={2}
                items={[
                {
                    title: 'Periodo de Formación',
                    description:
                    '<ul class="list-disc ml-6 mt-2 space-y-1 text-white"><li>El plan de estudios está compuesto de una secuencia básica de <strong>cuatro trimestres</strong> donde se concentran los <strong>doce cursos teóricos</strong> de acuerdo a la temática central de la mención doctoral y del trabajo de investigación del estudiante.</li><li>La <strong>Comisión Académica del Doctorado</strong> designará un Tutor, para el seguimiento de la formación como investigador del doctorando, en el momento de resolver la admisión, el cual orientará al estudiante en cuanto a la estructuración del plan de estudios de este periodo.</li></ul>',
                    icon: 'tabler:book',
                    classes: { 
                        panel: 'text-white bg-teal-700 dark:bg-teal-500/30',
                        icon: 'text-green-500'
                    },
                },
                {
                    title: 'Periodo de Investigación',
                    description:
                    '<ul class="list-disc ml-6 mt-2 space-y-1 text-white"><li><strong>Componente de Investigación</strong>; seminarios metodológicos y de evaluación cualitativa/cuantitativa.</li><li><strong>Tesis Doctoral</strong>; un trabajo de investigación final enfocado en proyectos sostenibles.</li><li><strong>Publicación de artículo científico</strong>.</li></ul>',
                    icon: 'tabler:microscope',
                    classes: { 
                        panel: 'text-white bg-teal-700 dark:bg-teal-500/30',
                        icon: 'text-green-500'
                    },
                },
                ]}
            />
            <!-- 4.1. Periodo de Formación -->
            <HeroSection
                tagline="Periodo de Formación"
                title="Carga Horaria y Asignaturas del Curso"
                subtitle='El plan de formación del <span class="text-primary font-semibold">Doctorado en Proyectos:</span> <span class="text-secondary font-semibold"> Línea de Investigación en Medio Ambiente</span> propone un recorrido 360º por las materias fundamentales para mejorar nuestra comprensión de la <strong>planeación, formulación y gestión de proyectos sostenibles</strong> tanto en el ambiente urbano como rural, en la micro y en la macro escala. Todas las asignaturas están directamente conectadas con un conjunto complejo de acciones y medidas que conducirán al diseño de un futuro sustentable desde una <strong>visión global</strong> que te permitirá asumir el liderazgo para la conducción de un proyecto o estrategia ecológica para disminuir el impacto ambiental, y son impartidas por profesores PhD expertos en cada materia.'
            >
                <Fragment slot="content">
                    <p class="text-base">El <strong>currículo del programa de doctorado</strong> se precisa a continuación:</p>
                    <ProgramCurriculum courses={proyectosInvestigacionCurriculum.courses} />
                </Fragment>
            </HeroSection>            
            <!-- 4.2. Periodo de Investigación -->
            <HeroSection
                tagline="Periodo de Investigación"
                title="Carga Horaria y Asignaturas del Seminario"                
            >
                <Fragment slot="content">
                    <ResearchCurriculum {...proyectosInvestigacionResearch} />
                </Fragment>
            </HeroSection>

            <!-- 5. PROYECTO DE TESIS DOCTORAL -->
            <PhdProject />

            <!-- 6. METODOLOGÍA DE ENSEÑANZA -->
            <ProgramMethodology />

            <!-- 7. PROFESORADO -->
            <Content
                id="profesorado"
                tagline="Profesorado"
                title="Profesorado y Tutoría"
                items={[
                    {
                        title: 'Composición del profesorado',
                        description:
                            'El profesorado está formado por personal universitario docente e investigador y por profesionales en activo en la administración pública y en la empresa privada, con residencia en varios países.',
                        icon: 'tabler:school',
                    },
                    {
                        title: 'Equipo central y habilidades complementarias',
                        description:
                            'Cuentan con un equipo central en Perú y habilidades complementarias que incluyen dominio de varios idiomas, experiencia con una amplia gama de culturas y la capacidad de trabajar de manera eficiente desde oficinas virtuales.',
                        icon: 'tabler:world-latitude',
                    },
                    {
                        title: 'Participación de profesionales externos',
                        description:
                            'Participan profesionales de primer nivel de otras empresas, organismos oficiales e instituciones, todos ellos directamente implicados en las diferentes áreas de conocimiento del programa.',
                        icon: 'tabler:users-group',
                    },
                ]}
                image={{
                    src: '~/assets/images/fvi-profesorado-tutoria.webp',
                    alt: 'Imagen del profesorado del Doctorado de Fondo Verde',
                }}
                >
                <Fragment slot="bg">
                    <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
                </Fragment>
            </Content>
            {
                ['juan-silva', 'gonzalo-fuente', 'alberto-jimenez', 'maria-teresa-perez', 'angel-guillemes', 'loraine-giraud', 'erick-brenes'].map((id) => (
                <FacultyMember {...faculty[id]}>
                    <Fragment slot="bg">
                    <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark" />
                    </Fragment>
                </FacultyMember>
                ))
            }

            <!-- 8. BENEFICIOS -->
            <Features
                id="beneficios"
                tagline="Beneficios"
                title="Beneficios anticipados e impacto profesional"
                subtitle='El <span class="text-primary font-semibold">Doctorado en Proyectos:</span> <span class="text-secondary font-semibold"> Línea de Investigación en Medio Ambiente</span>, es un investigador y proyectista del ambiente -social y natural- con capacidad de hacer aportes originales y significativos en el campo de las teorías de la sustentabilidad, el paradigma ambiental, y la gestión de proyectos ambientales. Un profesional que se constituya en un verdadero agente de cambio social y que posea profundos y sólidos conocimientos en las áreas objeto del doctorado. Para ello, cuenta con las siguientes competencias.'
                items={[
                    {
                        title: 'Identificación de Problemas',
                        description: 'Definirá un proyecto antes de comenzarlo a través de la identificación de un problema que se pretende solucionar.',
                        icon: 'tabler:bulb',
                    },
                    {
                        title: 'Instrumentos de Evaluación',
                        description: 'Contará con herramientas para proponer proyectos de alto impacto estratégico para el desarrollo sostenible.',
                        icon: 'tabler:report-analytics',
                    },
                    {
                        title: 'Ejecución de Proyectos Sostenibles',
                        description: 'Formula, diseña, ejecuta y evalúa proyectos en los ámbitos territoriales tendientes a incrementar su valor.',
                        icon: 'tabler:chart-bar',
                    },
                    {
                        title: 'Liderazgo Corporativo',
                        description: 'Lidera proyectos que generen valor económico y social a largo plazo.',
                        icon: 'tabler:users',
                    },
                ]}
            />    
            
            <!-- 9. CAMPOS DE ACCIÓN -->
            <Features
                id="campos-de-accion"
                tagline="Campos de Acción"
                title="Campos de Acción Profesionales"
                subtitle='Con el <span class="text-primary font-semibold">Doctorado en Proyectos:</span> <span class="text-secondary font-semibold"> Línea de Investigación en Medio Ambiente</span>, tendrá la capacidad para desempeñarse en los niveles máximos de dirección en organizaciones relacionadas con la conservación ambiental y el manejo de recursos naturales, tanto privadas como públicas; en organismos nacionales e internacionales de planeación y diseño de proyectos sostenibles de alto impacto.'
                items={[
                    {
                        title: 'Gestión en Entidades Locales',
                        description: 'Colabora con entidades locales en los aspectos ejecutores y operativos de programas y proyectos de desarrollo ambiental e investigación bajo el enfoque del desarrollo sustentable.',
                        icon: 'tabler:building-community',
                    },
                    {
                        title: 'Diagnósticos Locales y Regionales',
                        description: 'Colabora en la elaboración de diagnósticos a escala local y regional y en programas de desarrollo sostenible en un área geográfica determinada.',
                        icon: 'tabler:map-search',
                    },
                    {
                        title: 'Docencia e Investigación Superior',
                        description: 'Participa en instituciones académicas de nivel superior con programas de docencia, investigación, vinculación y gestión en el campo del desarrollo sostenible y la gestión de proyectos ambientales.',
                        icon: 'tabler:school',
                    },
                    {
                        title: 'Asesoría Estratégica Empresarial',
                        description: 'Trabaja para empresas que requieran de la realización y asesoría de planes estratégicos y estudios del desarrollo sustentable.',
                        icon: 'tabler:briefcase',
                    },
                    {
                        title: 'Consultoría en Proyectos Territoriales',
                        description: 'Consultor en el desarrollo y puesta en marcha de proyectos territoriales, programas, y emprendimientos de pequeños productores, de comunidades indígenas o campesinas.',
                        icon: 'tabler:users-group',
                    },
                ]}
            >
                <Fragment slot="bg">
                    <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
                </Fragment>
            </Features> 

            <!-- 10. TITULACIÓN -->            
            <Content
                id='titulacion'
                title='Título Oficial'
                tagline="Titulación"
                isReversed
                image={{
                    src: '~/assets/images/fvi-titulacion.webp',
                    alt: 'Imagen de titulación del Doctorado de Fondo Verde',
                }}
             >
                <Fragment slot="content">                    
                    <p class="text-xl text-muted mb-2 dark:text-slate-300">
                        La <strong>Universidad Centro Panamericano de Estudios Superiores</strong> - <strong>UNICEPES</strong>, otorga el Grado de <span class="text-primary font-semibold">Doctor (a) en Proyectos: Línea de Investigación en Medio Ambiente</span> con <strong>Reconocimiento de Validez Oficial de Estudios</strong> (<strong>RVOE</strong>) otorgado por la Secretaría de Educación del Gobierno del Estado de Michoacán (<span class="text-secondary font-semibold">RVOE No. DOC111202</span> | <span class="text-primary font-semibold">Clave D.G.P. Dirección General de Profesiones N° 620604</span>) y con Reconocimiento en todos los países en los que México haya suscrito convenio a través del Convenio de la Haya (1961).
                    </p>      
                    <div class="flex justify-center">
                        <div class="max-w-xs md:max-w-[400px]">
                            <Image 
                                src="~/assets/images/fvi-rvoe-logo.webp" 
                                alt="Logo RVOE" 
                                width={400}
                                class="h-auto dark:brightness-110"
                            />
                        </div>
                    </div>
                </Fragment>
            </Content>

            <!-- 11. BECAS -->
            <Scholarship />

            <!-- 12. INSCRIPCIÓN -->
            <Admission />

            <!-- 13. PAGOS -->
            <Payments />

            <!-- 14. MEDIOS DE PAGO -->
            <PaymentMethods />

            <!-- 15. SOLICITUDES -->
            <Requests />

        </div>
        <!-- END Main Content -->

    </div>
    <!-- END Desktop Sidebar & Mobile Floating Pill -->

</Layout>
