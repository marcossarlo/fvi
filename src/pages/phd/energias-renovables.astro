---
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import HeroPrograms from '~/components/widgets/HeroPrograms.astro';
import Layout from '~/layouts/PageLayout.astro';
import StatsData from '~/components/phd/StatsData.astro';
import ProgramTOC from '~/components/widgets/ProgramTOC.astro';
import Features from '~/components/widgets/Features.astro';
import HeroSection from '~/components/widgets/HeroSection.astro';
import ProgramCurriculum from '~/components/phd/ProgramCurriculum.astro';
import ResearchCurriculum from '~/components/phd/ResearchCurriculum.astro';
import ProgramMethodology from '~/components/phd/ProgramMethodology.astro';
import PhdProject from '~/components/phd/PhdProject.astro';
import { energiasCurriculum, energiasResearch } from '~/data/phd/energias-renovables';
import FacultyMember from '~/components/widgets/FacultyMember.astro';
import { faculty } from '~/data/faculty';
import Image from '~/components/common/Image.astro';
import Scholarship from '~/components/phd/Scholarship.astro';
import Admission from '~/components/phd/Admission.astro';
import Payments from '~/components/phd/Payments.astro';
import PaymentMethods from '~/components/phd/PaymentMethods.astro';
import Requests from '~/components/phd/Requests.astro';

const metadata = {
    title: 'Doctorado en Energías Renovables | Fondo Verde',
    description:
        'Fórmate con el Doctorado en Energías Renovables. Desarrolla investigación en energía eólica, biomasa, solar, marina, geotérmica e hidrógeno, impulsando la sostenibilidad energética con el respaldo académico y RVOE.',
    keywords:
        'doctorado energías renovables, sistemas solares, eólica, biomasa, hidrógeno verde, eficiencia energética, geotérmica, rvoe',
};

const tabs = [
    { id: 'presentacion', label: '1. Presentación' },
    { id: 'el-doctorado', label: '2. El Doctorado' },
    { id: 'investigacion', label: '3. Investigación' },
    { id: 'asignaturas', label: '4. Asignaturas' },
    { id: 'proyecto', label: '5. Proyecto' },
    { id: 'metodologia', label: '6. Metodología' },
    { id: 'profesorado', label: '7. Profesorado' },
    { id: 'beneficios', label: '8. Beneficios' },
    { id: 'campos-de-accion', label: '9. Campos de Acción' },
    { id: 'titulacion', label: '10. Titulación' },
    { id: 'becas', label: '11. Becas' },
    { id: 'inscripcion', label: '12. Inscripción' },
    { id: 'pagos', label: '13. Pagos' },
    { id: 'medios-de-pago', label: '14. Medios de Pago' },
    { id: 'solicitudes', label: '15. Solicitudes' },
];
---

<Layout metadata={metadata} showSecondaryNav={false}>
    <!-- HeroPrograms ********************************************** -->
    <HeroPrograms
        tagline="Convocatoria Abierta 2026"
        subtitle="Ingeniería y desarrollo aplicado a la transición energética global"
        actions={[
        {
            variant: 'primary',
            text: 'Solicita información',
            href: '#solicitudes',
            icon: 'tabler:mail-forward',
            class: '!bg-primary !border-primary !text-white hover:!bg-secondary hover:!border-secondary transition-colors duration-300',
        },
        ]}
        image={{
        src: '~/assets/images/doctorados/fvi-phd-sostenibilidad.webp',
        alt: 'Imagen del Doctorado en Energías Renovables',
        }}
    >
        <Fragment slot="title">
            Doctorado en <br />
            <span class="text-secondary dark:text-accent"> Energías Renovables</span>
        </Fragment>
    </HeroPrograms>

    <!-- DatosEstadisticas -->
    <StatsData /> 

    <div class="relative max-w-[100vw] overflow-x-hidden">
        <!-- Desktop Sidebar & Mobile Floating Pill -->
        <ProgramTOC tabs={tabs} />

        <!-- Main Content Wrapper that creates space for the Desktop Sidebar -->
        <div class="lg:ml-64 2xl:ml-[18rem] pb-24 lg:pb-0 transition-all duration-300">
            <!-- 1. PRESENTACIÓN *********************************** -->
            <Content
                id="presentacion"
                tagline="Presentación"
                title="Generadores de Transición Ambiental"
                subtitle="El programa está enfocado en proporcionar una formación avanzada en fuentes de energía limpias y eficientes como motor de la infraestructura actual, empleando innovación científica para la solución de problemas ambientales desde una perspectiva económica, de inversión y sustentable."
                items={[
                    {
                        title: 'Diversificación Energética',
                        description: 'Abarca múltiples tecnologías tales como la energía eólica, biomasa, solar, geotérmica y fuentes marinas, con especial impacto hacia el hidrógeno verde.',
                        icon: 'tabler:windmill',
                    },
                    {
                        title: 'Desarrollo en los mercados',
                        description: 'Facilita la cualificación de los investigadores para operar tanto en corporativas industriales como para dirigir organismos públicos y comisiones de energías gubernamentales.',
                        icon: 'tabler:coin',
                    },
                ]}
                image={{
                src: '~/assets/images/doctorados/fvi-phd-sostenibilidad-portada.webp',
                alt: 'Imagen de presentación del Doctorado de Energías Renovables',
                }}
            >
                <Fragment slot="bg">
                    <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
                </Fragment>
            </Content>

            <!-- 2. EL DOCTORADO  ******************************* -->
            <Features2
                id="el-doctorado"
                tagline="El Doctorado"
                title="¿Por qué cursar este Doctorado?"
                subtitle='El <span class="text-primary font-semibold">Doctorado en</span> <span class="text-secondary font-semibold">Energías Renovables</span> consolida investigadores altamente calificados para liderar centros productivos y diseñar líneas de mitigación sobre el cambio climático a gran escala.'
                columns={2}
                items={[
                {
                    title: 'Objetivos del Doctorado',
                    description:
                    'Nuestro objetivo principal es: <ul class="list-disc ml-6 mt-2 space-y-1 text-muted"><li>Formar investigadores especialistas en desarrollar políticas sustentables transfiriendo proyectos renovables sobre un espectro real y económico.</li><li>Producir modelos o tecnologías que logren eficientizar de manera técnica corporaciones y organismos sociales globales.</li></ul>',
                    icon: 'tabler:school',
                },
                {
                    title: 'Perfil del destinatario',
                    description:
                    'El programa está dirigido a: <ul class="list-disc ml-6 mt-2 space-y-1 text-muted"><li>Profesionales o doctores con base en Ingeniería, Termodinámica y Ciencias Ambientales interesados en la transición corporativa.</li><li>Tomadores de decisiones a nivel gubernamental operando en proyectos del Sector Energético o de infraestructura interurbana.</li></ul>',
                    icon: 'tabler:users',
                },
                ]}
            />

            <!-- 3. INVESTIGACIÓN  ******************************* -->
            <Features
                id="investigacion"
                tagline="Investigación"
                title="Sistemas de Transición"
                subtitle="El portafolio general del curso sitúa al estudiante a optimizar escenarios medioambientales mediante las principales líneas de generación de recursos."
                items={[
                    {
                        title: 'Eficiencia de Procesos Corporativos',
                        description: 'Proyectos y auditorías con enfoque en la manufactura verde para la reducción directa del consumo convencional de grandes infraestructuras.',
                        icon: 'tabler:chart-bar',
                    },
                    {
                        title: 'Evaluación del Potencial Bioclimático',
                        description: 'Investigación orientada hacia el recurso geotérmico y eólico en los mares previendo la sustentabilidad operativa intercontinental.',
                        icon: 'tabler:map',
                    },
                    {
                        title: 'Integración en Sistemas Integrales',
                        description: 'Generación, producción, almacenamiento y viabilidad actual aplicable en transporte o tecnología empleando hidrógeno como un vector masivo emergente.',
                        icon: 'tabler:engine',
                    },
                    {
                        title: 'Instalaciones Fotovoltaicas Alternativas',
                        description: 'Evaluación del diseño aislado o interconectado a la red de producción térmica para procesos locales y macro de alta concentración solar.',
                        icon: 'tabler:solar-panel',
                    },
                ]}
            >
                <Fragment slot="bg">
                    <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
                </Fragment>
            </Features>

            <!-- 4. ASIGNATURAS  ******************************* -->
            <!-- Carga horaria -->
            <Features2
                id="asignaturas"
                tagline="Asignaturas"
                title="Estructura del programa"
                subtitle='Es un programa multidisciplinario con una duración de <strong>24 meses</strong> (<strong>2 años</strong>), estructurado en periodos de formación, investigación, un <strong>Proyecto de Tesis Doctoral</strong> y artículo científico, totalizando <strong>1,600 horas lectivas</strong> (<strong>100 créditos</strong>).'
                columns={2}
                items={[
                {
                    title: 'Periodo de Formación',
                    description:
                    '<ul class="list-disc ml-6 mt-2 space-y-1 text-white"><li>El plan de estudios está compuesto de <strong>cuatro trimestres</strong> intensivos donde se dictan <strong>nueve cursos teóricos</strong> en sistemas renovables.</li><li>Garantiza el correcto enfoque del participante a través del acompañamiento de un Tutor nombrado por la <strong>Comisión Académica</strong>.</li></ul>',
                    icon: 'tabler:book',
                    classes: { 
                        panel: 'text-white bg-teal-700 dark:bg-teal-500/30',
                        icon: 'text-green-500'
                    },
                },
                {
                    title: 'Periodo de Investigación',
                    description:
                    '<ul class="list-disc ml-6 mt-2 space-y-1 text-white"><li><strong>Componente de Investigación</strong>; seminarios metodológicos referidos a las estrategias de reducción en materia climática.</li><li><strong>Tesis Doctoral</strong>; enfoque escrito hacia problemáticas operativas independientes evaluando los ejes en las formas variables de fuentes no fósiles.</li><li><strong>Publicación de un artículo científico</strong>.</li></ul>',
                    icon: 'tabler:microscope',
                    classes: { 
                        panel: 'text-white bg-teal-700 dark:bg-teal-500/30',
                        icon: 'text-green-500'
                    },
                },
                ]}
            />
            <!-- 4.1. Periodo de Formación -->
            <HeroSection
                tagline="Periodo de Formación"
                title="Carga Horaria y Asignaturas del Curso"
                subtitle='Estudio completo en 360 grados de todos los factores energéticos en la biosfera; evaluando potencial global, instalaciones medibles y tecnologías emergentes de nueva escala.'
            >
                <Fragment slot="content">
                    <p class="text-base text-left mb-6">El <strong>currículo del programa de doctorado</strong> se precisa a continuación:</p>
                    <ProgramCurriculum courses={energiasCurriculum.courses} />
                </Fragment>
            </HeroSection>            
            <!-- 4.2. Periodo de Investigación -->
            <HeroSection
                tagline="Periodo de Investigación"
                title="Carga Horaria y Asignaturas del Seminario"                
            >
                <Fragment slot="content">
                    <ResearchCurriculum {...energiasResearch} />
                </Fragment>
            </HeroSection>

            <!-- 5. PROYECTO DE TESIS DOCTORAL -->
            <PhdProject />

            <!-- 6. METODOLOGÍA DE ENSEÑANZA -->
            <ProgramMethodology />

            <!-- 7. PROFESORADO -->
            <Content
                id="profesorado"
                tagline="Profesorado"
                title="Profesorado y Tutoría"
                items={[
                    {
                        title: 'Investigación Activa Corporativa',
                        description:
                            'Las áreas de evaluación y estudio son dirigidas por doctores e ingenieros involucrados activamente en el sector energético público y privado orientados a escala transnacional o mundial.',
                        icon: 'tabler:school',
                    },
                    {
                        title: 'Asistencia y Cultura Multilingüe',
                        description:
                            'Metodología global operada desde oficinas virtuales por técnicos involucrados e implicados de primer nivel para cada una de las industrias representadas durante el esquema.',
                        icon: 'tabler:world',
                    },
                ]}
                image={{
                    src: '~/assets/images/fvi-profesorado-tutoria.webp',
                    alt: 'Imagen del profesorado del Doctorado de Fondo Verde',
                }}
                >
                <Fragment slot="bg">
                    <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
                </Fragment>
            </Content>
            {
                ['angel-guillemes', 'juan-silva', 'angela-martin', 'alberto-jimenez', 'eduardo-marquez', 'erick-brenes'].map((id) => {
                    const prof = faculty[id];
                    if(!prof) return null;
                    return (
                    <FacultyMember {...prof}>
                        <Fragment slot="bg">
                        <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark" />
                        </Fragment>
                    </FacultyMember>
                    )
                })
            }

            <!-- 8. BENEFICIOS -->
            <Features
                id="beneficios"
                tagline="Beneficios"
                title="Beneficios anticipados e impacto profesional"
                subtitle="Visión y conocimiento a nivel macro sobre los medios de infraestructura económica regional para una óptima resiliencia del sector humano."
                items={[
                    {
                        title: 'Dirección de Entidades Energéticas',
                        description: 'Apertura hacia organismos oficiales implementando innovación para sustitución del parque convencional de extracción fósil.',
                        icon: 'tabler:certificate',
                    },
                    {
                        title: 'Liderazgo en Desarrollo Sostenido',
                        description: 'Ventaja estratégica técnica para supervisar procesos, certificaciones y cumplimiento sobre normativas orientadas en manufactura en continentes con estricta gestión industrial.',
                        icon: 'tabler:star',
                    },
                    {
                        title: 'Diseño Consultivo y Académico',
                        description: 'Concepción operativa y académica orientando nuevas estrategias de investigación que sirvan hacia líneas políticas corporativas.',
                        icon: 'tabler:chart-bar',
                    },
                    {
                        title: 'Integración Internacional y Transición',
                        description: 'Proyectista con base calificada para el desarrollo y licitaciones de transición vinculándose localmente en oportunidades para comunidades de escasa electrificación rural territorial.',
                        icon: 'tabler:shield-check',
                    },
                ]}
            />    
            
            <!-- 9. CAMPOS DE ACCIÓN -->
            <Features
                id="campos-de-accion"
                tagline="Campos de Acción"
                title="Campos de Acción Profesionales"
                subtitle="El doctor en energías renovables recibe formación superior calificada en los sistemas con más futuro dentro de los planes de gestión y estado."
                items={[
                    {
                        title: 'Gestores de Política Nacionales',
                        description: 'Miembros e investigadores de estamentos promotores, como cámaras empresariales para orientar planes constructivos y directos de evaluación e instalación limpia y asequible.',
                        icon: 'tabler:building-bank',
                    },
                    {
                        title: 'Asesores de Industrias Energéticas',
                        description: 'Dirimentes directivos y directores para campos en expansión, abarcando geotermia, biomasa e infraestructura eólica previendo un mejor posicionamiento bursátil de sus consorcios.',
                        icon: 'tabler:engine',
                    },
                    {
                        title: 'Docente y Coordinador Tecnológico',
                        description: 'Cátedra en programas de pregrado evaluando e incorporando programas sociales experimentales desde el pilar académico superior o laboratorios experimentales de prototipos.',
                        icon: 'tabler:microscope',
                    },
                    {
                        title: 'Gerente Auditor de Eficiencia',
                        description: 'Supervisión en consumos de infraestructura general integrando recursos biológicos aislados de manera factible a través sistemas directos o de hidrógeno al mercado real.',
                        icon: 'tabler:clipboard-check',
                    },
                ]}
            >
                <Fragment slot="bg">
                    <div class="absolute inset-0 bg-blue-50 dark:bg-pageDark"></div>
                </Fragment>
            </Features> 

            <!-- 10. TITULACIÓN -->            
            <Content
                id='titulacion'
                title='Título Oficial'
                tagline="Titulación"
                isReversed
                image={{
                    src: '~/assets/images/fvi-titulacion.webp',
                    alt: 'Imagen de titulación del Doctorado de Fondo Verde',
                }}
             >
                <Fragment slot="content">                    
                    <p class="text-xl text-muted mb-2 dark:text-slate-300">
                        La <strong>Universidad Centro Panamericano de Estudios Superiores</strong> - <strong>UNICEPES</strong>, otorga el Grado de <span class="text-primary font-semibold">Doctor (a) en Energías Renovables</span> con <strong>Reconocimiento de Validez Oficial de Estudios</strong> (<strong>RVOE</strong>) otorgado por la Secretaría de Educación del Gobierno del Estado de Michoacán (<span class="text-secondary font-semibold">RVOE No. DOC210101</span> | <span class="text-primary font-semibold">Clave D.G.P. Dirección General de Profesiones N° 613626</span>) y con Reconocimiento en todos los países en los que México haya suscrito convenio a través del Convenio de la Haya (1961).
                    </p>      
                    <div class="flex justify-center">
                        <div class="max-w-xs md:max-w-[400px]">
                            <Image 
                                src="~/assets/images/fvi-rvoe-logo.webp" 
                                alt="Logo RVOE" 
                                width={400}
                                class="h-auto dark:brightness-110"
                            />
                        </div>
                    </div>
                </Fragment>
            </Content>

            <!-- 11. BECAS -->
            <Scholarship />

            <!-- 12. INSCRIPCIÓN -->
            <Admission />

            <!-- 13. PAGOS -->
            <Payments />

            <!-- 14. MEDIOS DE PAGO -->
            <PaymentMethods />

            <!-- 15. SOLICITUDES -->
            <Requests />

        </div>
        <!-- END Main Content -->

    </div>
    <!-- END Desktop Sidebar & Mobile Floating Pill -->

</Layout>
